SC_LAB_WORKER_COORDINATOR_URL=https://your-lab-compute-core.example.com
SC_LAB_WORKER_ID=local-mac-worker-01
SC_LAB_WORKER_NAME=Local Mac Scientific Worker
SC_LAB_WORKER_TYPE=local-python
SC_LAB_WORKER_ENROLLMENT_TOKEN=replace-with-coordinator-enrollment-token
SC_LAB_WORKER_CONTRACT_SECRET=replace-with-coordinator-contract-secret
SC_LAB_WORKER_CREDENTIAL_FILE=~/.config/sustainable-catalyst-lab/worker-credential.json
SC_LAB_WORKER_TAGS=trusted,python-core,local
SC_LAB_WORKER_METHODS=
SC_LAB_WORKER_PACKAGES=
SC_LAB_WORKER_MEMORY_MB=4096
SC_LAB_WORKER_CPU_CORES=4
SC_LAB_WORKER_MAX_CONCURRENT_JOBS=1
SC_LAB_WORKER_CHECKPOINTING=1
SC_LAB_WORKER_LOCAL_DATA=0
SC_LAB_WORKER_POLL_INTERVAL_SECONDS=5
SC_LAB_WORKER_HEARTBEAT_INTERVAL_SECONDS=30
SC_LAB_WORKER_LEASE_SECONDS=300
SC_LAB_WORKER_REQUEST_TIMEOUT_SECONDS=30
SC_LAB_WORKER_ALLOW_INSECURE_CONTRACTS=0

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>Label</key><string>com.sustainablecatalyst.lab-worker-agent</string>
<key>ProgramArguments</key><array><string>/usr/bin/env</string><string>bash</string><string>/absolute/path/to/backend/scripts/run_worker_agent.sh</string></array>
<key>WorkingDirectory</key><string>/absolute/path/to/backend</string>
<key>RunAtLoad</key><true/><key>KeepAlive</key><true/>
<key>StandardOutPath</key><string>/tmp/sc-lab-worker-agent.log</string>
<key>StandardErrorPath</key><string>/tmp/sc-lab-worker-agent.err</string>
</dict></plist>

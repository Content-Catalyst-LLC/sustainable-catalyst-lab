SC_LAB_ENVIRONMENT=development
SC_LAB_COMPUTE_API_KEY=replace-with-long-random-value
SC_LAB_COMPUTE_SIGNING_SECRET=replace-with-a-different-long-random-value
SC_LAB_SIGNATURE_TOLERANCE_SECONDS=300
SC_LAB_MAX_REQUEST_BYTES=262144
SC_LAB_LOAD_LEGACY_EXTENSIONS=1

# v0.27.3 precision governance plus persistent queue, checkpoints, project limits, and result cache
SC_LAB_JOB_DB_PATH=./data/sc-lab-compute-jobs.sqlite3
SC_LAB_JOB_WORKERS=2
SC_LAB_MAX_QUEUED_JOBS=100
SC_LAB_DEFAULT_JOB_TIMEOUT_SECONDS=60
SC_LAB_MAX_JOB_TIMEOUT_SECONDS=900
SC_LAB_DEFAULT_JOB_ATTEMPTS=2
SC_LAB_MAX_JOB_ATTEMPTS=5
SC_LAB_RETRY_BASE_DELAY_SECONDS=2
SC_LAB_MAX_RETRY_DELAY_SECONDS=60
SC_LAB_JOB_DEDUPE_WINDOW_SECONDS=86400
SC_LAB_JOB_RETENTION_SECONDS=604800
SC_LAB_MAX_ACTIVE_JOBS_PER_PROJECT=5
SC_LAB_CHECKPOINT_RETENTION_PER_JOB=20
SC_LAB_MAX_CHECKPOINT_BYTES=8388608
SC_LAB_RESULT_CACHE_TTL_SECONDS=86400
SC_LAB_MAX_CACHE_RECORDS=250
SC_LAB_DEFAULT_JOB_PRIORITY=50

# v0.31.0 Distributed Compute Dispatcher
SC_LAB_DISPATCHER_WORKER_STALE_SECONDS=120
SC_LAB_DISPATCHER_DEFAULT_LEASE_SECONDS=300
SC_LAB_DISPATCHER_MAX_WORKERS=500

SC_LAB_DISPATCHER_DB_PATH=./data/sc-lab-dispatcher.sqlite3
SC_LAB_DISPATCHER_MAX_QUEUE_RECORDS=5000
SC_LAB_DISPATCHER_MAX_ATTEMPTS=5
SC_LAB_DISPATCHER_HISTORY_LIMIT=10000
SC_LAB_DISPATCHER_PERSISTENT_DISK_MOUNTED=0

# v0.31.2 Secure Worker Agent Runtime
SC_LAB_DISPATCHER_CONTRACT_SECRET=replace-with-worker-contract-verification-secret
SC_LAB_WORKER_ENROLLMENT_TOKEN=replace-with-worker-enrollment-token
SC_LAB_ALLOW_OPEN_WORKER_ENROLLMENT=0

# v0.31.3 Distributed Artifact, Result, and Checkpoint Transport
SC_LAB_ARTIFACT_ROOT=./data/artifacts
SC_LAB_ARTIFACT_DB_PATH=
SC_LAB_ARTIFACT_MAX_BYTES=268435456
SC_LAB_ARTIFACT_CHUNK_BYTES=1048576
SC_LAB_ARTIFACT_UPLOAD_TTL_SECONDS=86400
SC_LAB_ARTIFACT_RETENTION_SECONDS=2592000
SC_LAB_ARTIFACT_PERSISTENT_DISK_MOUNTED=0
SC_LAB_WORKER_RESULT_ARTIFACT_THRESHOLD_BYTES=262144

# v0.31.4 Dispatcher Operations, Dead-Letter Recovery, and Observability
SC_LAB_DISPATCHER_RETRY_BASE_DELAY_SECONDS=15
SC_LAB_DISPATCHER_RETRY_MAX_DELAY_SECONDS=900

# v0.32.1 Workflow Checkpoints, Conditional Execution, and Partial Recovery
SC_LAB_WORKFLOW_DB_PATH=./data/sc-lab-workflows.sqlite3
SC_LAB_WORKFLOW_MAX_NODES=100
SC_LAB_WORKFLOW_MAX_RUNS=5000
SC_LAB_WORKFLOW_HISTORY_LIMIT=20000
SC_LAB_WORKFLOW_PERSISTENT_DISK_MOUNTED=0

# v0.32.2 Scheduled and Event-Driven Research Runs
SC_LAB_WORKFLOW_SCHEDULE_DB_PATH=./data/sc-lab-workflow-schedules.sqlite3
SC_LAB_WORKFLOW_SCHEDULER_POLL_SECONDS=30
SC_LAB_WORKFLOW_SCHEDULER_MAX_CATCH_UP_RUNS=10
SC_LAB_WORKFLOW_SCHEDULER_HISTORY_LIMIT=20000
SC_LAB_WORKFLOW_EVENT_SECRET=
SC_LAB_WORKFLOW_EVENT_SIGNATURE_TOLERANCE_SECONDS=300
SC_LAB_WORKFLOW_SCHEDULE_PERSISTENT_DISK_MOUNTED=0

# v0.33.1 Bayesian Optimization, Active Learning, and Resource-Aware Search
SC_LAB_EXPERIMENT_CAMPAIGN_DB_PATH=./data/sc-lab-experiment-campaigns.sqlite3
SC_LAB_EXPERIMENT_CAMPAIGN_POLL_SECONDS=30
SC_LAB_EXPERIMENT_CAMPAIGN_MAX_CAMPAIGNS=1000
SC_LAB_EXPERIMENT_CAMPAIGN_MAX_TRIALS=10000
SC_LAB_EXPERIMENT_CAMPAIGN_HISTORY_LIMIT=30000
SC_LAB_EXPERIMENT_CAMPAIGN_PERSISTENT_DISK_MOUNTED=0

# v0.33.2 Closed-Loop Simulation and Instrument Campaigns
SC_LAB_CLOSED_LOOP_DB_PATH=./data/sc-lab-closed-loop-campaigns.sqlite3
SC_LAB_CLOSED_LOOP_POLL_SECONDS=30
SC_LAB_CLOSED_LOOP_MAX_LOOPS=1000
SC_LAB_CLOSED_LOOP_MAX_CYCLES=100000

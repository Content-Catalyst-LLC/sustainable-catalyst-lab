# Optional Render persistent disk configuration.
# Persistent disks are not included in the default blueprint because they may require a paid service.
# Merge this block into the web service only when durable queue, result, and checkpoint storage is desired.
disk:
  name: sustainable-catalyst-lab-data
  mountPath: /app/data
  sizeGB: 1
envVars:
  - key: SC_LAB_JOB_DB_PATH
    value: /app/data/sc-lab-compute-jobs.sqlite3
  - key: SC_LAB_DISPATCHER_DB_PATH
    value: /app/data/sc-lab-dispatcher.sqlite3
  - key: SC_LAB_DISPATCHER_PERSISTENT_DISK_MOUNTED
    value: "1"
  - key: SC_LAB_ARTIFACT_ROOT
    value: /app/data/artifacts
  - key: SC_LAB_ARTIFACT_DB_PATH
    value: /app/data/sc-lab-artifacts.sqlite3
  - key: SC_LAB_ARTIFACT_PERSISTENT_DISK_MOUNTED
    value: "1"
  - key: SC_LAB_MODEL_REGISTRY_DB_PATH
    value: /app/data/sc-lab-model-registry.sqlite3
  - key: SC_LAB_MODEL_REGISTRY_PERSISTENT_DISK_MOUNTED
    value: "1"


# Offline field and edge synchronization
# SC_LAB_EDGE_SYNC_DB_PATH=/app/data/sc-lab-edge-sync.sqlite3
# SC_LAB_EDGE_SYNC_PERSISTENT_DISK_MOUNTED=1

  - key: SC_LAB_PUBLICATION_STUDIO_DB_PATH
    value: /app/data/sc-lab-publication-studio.sqlite3
  - key: SC_LAB_PUBLICATION_STUDIO_PERSISTENT_DISK_MOUNTED
    value: "1"

# v0.38.0 interoperability storage

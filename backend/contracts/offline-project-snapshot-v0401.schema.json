{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/offline-project-snapshot-v0401.schema.json",
  "title": "Offline Project Snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schema",
    "projectId",
    "workspaceId",
    "classification",
    "assets",
    "backendStoresRawPayload",
    "recordHash"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schema": {
      "const": "sc-lab-offline-project-snapshot/0.40.1"
    },
    "projectId": {
      "type": "string"
    },
    "workspaceId": {
      "type": "string"
    },
    "classification": {
      "enum": [
        "public",
        "internal",
        "confidential"
      ]
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "backendStoresRawPayload": {
      "const": false
    },
    "recordHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}

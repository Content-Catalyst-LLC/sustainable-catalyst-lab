{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sc-lab-institution/0.39.0",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "name",
    "status",
    "domains",
    "settings",
    "institutionHash",
    "createdBy",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-institution/0.39.0"
    },
    "version": {
      "const": "0.39.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "active",
        "suspended",
        "archived"
      ]
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "settings": {
      "type": "object"
    },
    "institutionHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "currentRoles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}

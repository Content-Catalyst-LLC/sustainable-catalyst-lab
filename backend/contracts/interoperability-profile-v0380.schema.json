{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/interoperability-profile-v0380.schema.json",
  "title": "Research Interoperability Profile",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "workspaceId",
    "productId",
    "supportedContracts",
    "capabilities",
    "profileHash"
  ],
  "properties": {
    "schema": {
      "const": "sc-research-interoperability-profile/0.38.0"
    },
    "version": {
      "const": "0.38.0"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "workspaceId": {
      "type": "string"
    },
    "productId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,78}[a-z0-9]$"
    },
    "displayName": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "suspended",
        "deprecated"
      ]
    },
    "supportedContracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._/-]+/[0-9]+\\.[0-9]+$"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    },
    "profileHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}

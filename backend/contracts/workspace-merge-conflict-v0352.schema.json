    },
    "workspaceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "base": {},
    "source": {},
    "target": {},
    "status": {
      "enum": [
        "open",
        "resolved"
      ]
    },
    "resolution": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "base",
        "custom",
        "source",
        "target",
        null
      ]
    },
    "resolvedValue": {},
    "conflictHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "resolvedBy": {
      "anyOf": [

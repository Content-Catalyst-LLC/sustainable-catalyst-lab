{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sustainable Catalyst Lab Scientific Model Version v0.34.0",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "version", "modelId", "modelVersion", "title", "projectId", "type", "environment", "modelHash"],
  "properties": {
    "schema": {"const": "sc-lab-scientific-model-version/0.34.0"},
    "version": {"const": "0.34.0"},
    "modelId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,179}$"},
    "modelVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"},
    "title": {"type": "string", "minLength": 1},
    "projectId": {"type": "string"},
    "type": {"enum": ["registered-method", "workflow", "surrogate", "calibrated-model", "external-artifact"]},
    "methodId": {"type": ["string", "null"]},
    "workflowId": {"type": ["string", "null"]},
    "artifactIds": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "environment": {"$ref": "reproduction-environment-v0340.schema.json"},
    "modelHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "inputSchema": {"type": "object"},
    "outputSchema": {"type": "object"},
    "defaultInputs": {"type": "object"},
    "parameters": {"type": "object"},
    "provenance": {"type": "object"},
    "metadata": {"type": "object"}
  }
}

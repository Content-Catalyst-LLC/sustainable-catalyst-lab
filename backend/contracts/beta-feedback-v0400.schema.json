{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Beta Feedback Record v0.40.0",
  "type": "object",
  "required": [
    "id",
    "category",
    "severity",
    "status",
    "title",
    "description",
    "reporterHash",
    "recordHash"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "category": {
      "type": [
        "string",
        "null"
      ]
    },
    "severity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "reporterHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "recordHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}

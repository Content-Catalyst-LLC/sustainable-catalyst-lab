{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/federation-conflict-v0360.schema.json",
  "title": "Federation Conflict v0.36.0",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "workspaceId",
    "sourceId",
    "collectionId",
    "canonicalUri",
    "status",
    "conflictHash"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-federation-conflict/0.36.0"
    },
    "version": {
      "const": "0.36.0"
    },
    "id": {
      "type": "string"
    },
    "workspaceId": {
      "type": "string"
    },
    "sourceId": {
      "type": "string"
    },
    "collectionId": {
      "type": "string"
    },
    "canonicalUri": {
      "type": "string"
    },
    "status": {
      "enum": [
        "open",
        "resolved"
      ]
    },
    "conflictHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}

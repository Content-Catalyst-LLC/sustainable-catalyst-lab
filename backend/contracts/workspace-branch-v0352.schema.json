{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/workspace-branch-v0352.schema.json",
  "title": "Workspace Branch v0.35.2",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "workspaceId",
    "name",
    "status",
    "protected",
    "revision"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-workspace-branch/0.35.2"
    },
    "version": {
      "const": "0.35.2"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "status": {
      "enum": [
        "active",
        "merged",
        "archived"
      ]
    },
    "protected": {
      "type": "boolean"
    },
    "baseSnapshotId": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "headSnapshotId": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "createdBy": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "mergedAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": true
}

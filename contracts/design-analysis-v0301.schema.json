    },
    "matrixId": {
      "type": "string"
    },
    "coefficients": {
      "type": "array"
    },
    "analysisHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
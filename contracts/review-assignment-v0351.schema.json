{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lab Review Assignment v0.35.1",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "workspaceId",
    "resourceLinkId",
    "reviewerId",
    "status",
    "revision"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-review-assignment/0.35.1"
    },
    "version": {
      "const": "0.35.1"
    },
    "id": {
      "type": "string"
    },
    "workspaceId": {
      "type": "string"
    },
    "resourceLinkId": {
      "type": "string"
    },
    "reviewerId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "assigned",
        "in-review",
        "approved",
        "changes-requested",
        "withdrawn"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment comparison v0.30.0",
  "type": "object",
  "required": [
    "schema",
    "runIds",
    "comparisonHash"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-experiment-comparison/0.30.0"
    },
    "runIds": {
      "type": "array",
      "minItems": 2
    },
    "comparisonHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
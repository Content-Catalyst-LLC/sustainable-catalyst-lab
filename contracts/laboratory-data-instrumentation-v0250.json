{
  "schema": "sc-lab-laboratory-instrumentation-contract/1.0",
  "version": "0.25.0",
  "title": "Laboratory Data and Instrumentation Platform",
  "categories": [
    {
      "id": "acquisition-design",
      "label": "Acquisition Design",
      "description": "Sampling, throughput, storage, and ADC calculations."
    },
    {
      "id": "calibration",
      "label": "Calibration and Verification",
      "description": "Linear calibration, error, drift, and due-date calculations."
    },
    {
      "id": "measurement-statistics",
      "label": "Measurement Statistics",
      "description": "Descriptive statistics and variability for laboratory measurements."
    },
    {
      "id": "signal-conditioning",
      "label": "Signal Conditioning",
      "description": "Smoothing, interpolation, integration, and derivative calculations."
    },
    {
      "id": "unit-normalization",
      "label": "Unit Normalization",
      "description": "Temperature, pressure, volume, and mass conversions."
    },
    {
      "id": "temporal-normalization",
      "label": "Temporal Normalization",
      "description": "Intervals, offsets, rates, and schedule timing."
    },
    {
      "id": "data-quality",
      "label": "Data Quality",
      "description": "Completeness, duplication, range, clipping, and composite quality."
    },
    {
      "id": "operational-integrity",
      "label": "Operational Integrity",
      "description": "Custody, maintenance, uptime, and record completeness."
    }
  ],
  "methods": [
    {
      "id": "sample-rate-from-interval",
      "label": "Sample rate from interval",
      "category": "acquisition-design",
      "operation": "sample_rate_from_interval",
      "inputs": [
        {
          "key": "intervalSeconds",
          "label": "Sample interval",
          "unit": "s",
          "type": "number",
          "min": 1e-12
        }
      ],
      "output": {
        "unit": "Hz"
      },
      "formula": "fs=1/dt"
    },
    {
      "id": "sample-interval-ms",
      "label": "Sample interval",
      "category": "acquisition-design",
      "operation": "sample_interval_ms",
      "inputs": [
        {
          "key": "sampleRateHz",
          "label": "Sample rate",
          "unit": "Hz",
          "type": "number",
          "min": 1e-12
        }
      ],
      "output": {
        "unit": "ms"
      },
      "formula": "dt=1000/fs"
    },
    {
      "id": "sample-count",
      "label": "Sample count",
      "category": "acquisition-design",
      "operation": "sample_count",
      "inputs": [
        {
          "key": "durationSeconds",
          "label": "Duration",
          "unit": "s",
          "type": "number",
          "min": 0
        },
        {
          "key": "sampleRateHz",
          "label": "Sample rate",
          "unit": "Hz",
          "type": "number",
          "min": 1e-12
        }
      ],
      "output": {
        "unit": "samples"
      },
      "formula": "N=round(t*fs)"
    },
    {
      "id": "acquisition-duration",
      "label": "Acquisition duration",
      "category": "acquisition-design",
      "operation": "acquisition_duration",
      "inputs": [
        {
          "key": "sampleCount",
          "label": "Sample count",
          "unit": "samples",
          "type": "number",
          "min": 0
        },
        {
          "key": "sampleRateHz",
          "label": "Sample rate",
          "unit": "Hz",
          "type": "number",
          "min": 1e-12
        }
      ],
      "output": {
        "unit": "s"
      },
      "formula": "t=N/fs"
    },
    {
      "id": "data-throughput",
      "label": "Data throughput",
      "category": "acquisition-design",
      "operation": "data_throughput",
      "inputs": [
        {
          "key": "sampleRateHz",
          "label": "Sample rate",
          "unit": "Hz",
          "type": "number",
          "min": 0
        },
        {
          "key": "channelCount",
          "label": "Channels",
          "unit": "channels",
          "type": "number",
          "min": 0
        },
        {
          "key": "bytesPerSample",
          "label": "Bytes per sample",
          "unit": "B",
          "type": "number",
          "min": 0
        }
      ],
      "output": {
        "unit": "B/s"
      },
      "formula": "R=fs*C*B"
    },
    {
      "id": "storage-size",
      "label": "Storage size",
      "category": "acquisition-design",
      "operation": "storage_size",
      "inputs": [
        {
          "key": "durationSeconds",
          "label": "Duration",
          "unit": "s",
          "type": "number",
          "min": 0
        },
        {
          "key": "throughputBytesPerSecond",
          "label": "Throughput",
          "unit": "B/s",
          "type": "number",
          "min": 0
        }
      ],
      "output": {
        "unit": "MB"
      },
      "formula": "size=t*R/1e6"
    },
    {
      "id": "adc-levels",
      "label": "ADC levels",
      "category": "acquisition-design",
      "operation": "adc_levels",
      "inputs": [
        {
          "key": "bits",
          "label": "Resolution",
          "unit": "bits",
          "type": "number",
          "min": 1
        }
      ],
      "output": {
        "unit": "levels"
      },
      "formula": "levels=2^bits"
    },
    {
      "id": "quantization-step",
      "label": "Quantization step",
      "category": "acquisition-design",
      "operation": "quantization_step",
      "inputs": [
        {
          "key": "inputRange",
          "label": "Input range",
          "unit": "V",
          "type": "number",
          "min": 1e-12
        },
        {
          "key": "bits",
          "label": "Resolution",
          "unit": "bits",
          "type": "number",
          "min": 1
        }
      ],
      "output": {
        "unit": "V/level"
      },
      "formula": "q=range/(2^bits-1)"
    },
    {
      "id": "two-point-gain",
      "label": "Two-point calibration gain",
      "category": "calibration",
      "operation": "two_point_gain",
      "inputs": [
        {
          "key": "rawLow",
          "label": "Raw low",
          "unit": "",
          "type": "number"
        },
        {
          "key": "rawHigh",
          "label": "Raw high",
          "unit": "",
          "type": "number"
        },
        {
          "key": "referenceLow",
          "label": "Reference low",
          "unit": "",
          "type": "number"
        },
        {
          "key": "referenceHigh",
          "label": "Reference high",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "ratio"
      },
      "formula": "gain=(refH-refL)/(rawH-rawL)"
    },
    {
      "id": "two-point-offset",
      "label": "Two-point calibration offset",
      "category": "calibration",
      "operation": "two_point_offset",
      "inputs": [
        {
          "key": "rawLow",
          "label": "Raw low",
          "unit": "",
          "type": "number"
        },
        {
          "key": "referenceLow",
          "label": "Reference low",
          "unit": "",
          "type": "number"
        },
        {
          "key": "gain",
          "label": "Gain",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "offset=refL-gain*rawL"
    },
    {
      "id": "apply-linear-calibration",
      "label": "Apply linear calibration",
      "category": "calibration",
      "operation": "apply_calibration",
      "inputs": [
        {
          "key": "rawValue",
          "label": "Raw value",
          "unit": "",
          "type": "number"
        },
        {
          "key": "gain",
          "label": "Gain",
          "unit": "",
          "type": "number"
        },
        {
          "key": "offset",
          "label": "Offset",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "y=gain*x+offset"
    },
    {
      "id": "inverse-linear-calibration",
      "label": "Inverse linear calibration",
      "category": "calibration",
      "operation": "inverse_calibration",
      "inputs": [
        {
          "key": "calibratedValue",
          "label": "Calibrated value",
          "unit": "",
          "type": "number"
        },
        {
          "key": "gain",
          "label": "Gain",
          "unit": "",
          "type": "number"
        },
        {
          "key": "offset",
          "label": "Offset",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "raw units"
      },
      "formula": "x=(y-offset)/gain"
    },
    {
      "id": "absolute-error",
      "label": "Absolute calibration error",
      "category": "calibration",
      "operation": "absolute_error",
      "inputs": [
        {
          "key": "measured",
          "label": "Measured",
          "unit": "",
          "type": "number"
        },
        {
          "key": "reference",
          "label": "Reference",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "abs(measured-reference)"
    },
    {
      "id": "percent-error",
      "label": "Percent calibration error",
      "category": "calibration",
      "operation": "percent_error",
      "inputs": [
        {
          "key": "measured",
          "label": "Measured",
          "unit": "",
          "type": "number"
        },
        {
          "key": "reference",
          "label": "Reference",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "abs(measured-reference)/abs(reference)*100"
    },
    {
      "id": "drift-rate",
      "label": "Calibration drift rate",
      "category": "calibration",
      "operation": "drift_rate",
      "inputs": [
        {
          "key": "initialValue",
          "label": "Initial",
          "unit": "",
          "type": "number"
        },
        {
          "key": "finalValue",
          "label": "Final",
          "unit": "",
          "type": "number"
        },
        {
          "key": "elapsedHours",
          "label": "Elapsed time",
          "unit": "h",
          "type": "number",
          "min": 1e-12
        }
      ],
      "output": {
        "unit": "units/h"
      },
      "formula": "(final-initial)/hours"
    },
    {
      "id": "calibration-due-days",
      "label": "Calibration days remaining",
      "category": "calibration",
      "operation": "calibration_due_days",
      "inputs": [
        {
          "key": "intervalDays",
          "label": "Calibration interval",
          "unit": "days",
          "type": "number",
          "min": 0
        },
        {
          "key": "daysSinceCalibration",
          "label": "Days since calibration",
          "unit": "days",
          "type": "number",
          "min": 0
        }
      ],
      "output": {
        "unit": "days"
      },
      "formula": "interval-elapsed"
    },
    {
      "id": "measurement-mean",
      "label": "Measurement mean",
      "category": "measurement-statistics",
      "operation": "mean",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "mean(x)"
    },
    {
      "id": "measurement-median",
      "label": "Measurement median",
      "category": "measurement-statistics",
      "operation": "median",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "median(x)"
    },
    {
      "id": "measurement-sd",
      "label": "Sample standard deviation",
      "category": "measurement-statistics",
      "operation": "sd",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "sd(x)"
    },
    {
      "id": "measurement-cv",
      "label": "Coefficient of variation",
      "category": "measurement-statistics",
      "operation": "cv",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "sd/abs(mean)*100"
    },
    {
      "id": "measurement-min",
      "label": "Minimum measurement",
      "category": "measurement-statistics",
      "operation": "minimum",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "min(x)"
    },
    {
      "id": "measurement-max",
      "label": "Maximum measurement",
      "category": "measurement-statistics",
      "operation": "maximum",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "max(x)"
    },
    {
      "id": "measurement-range",
      "label": "Measurement range",
      "category": "measurement-statistics",
      "operation": "range",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "max-min"
    },
    {
      "id": "measurement-rms",
      "label": "Root mean square",
      "category": "measurement-statistics",
      "operation": "rms",
      "inputs": [
        {
          "key": "values",
          "label": "Measurements",
          "unit": "",
          "type": "array",
          "minItems": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "sqrt(mean(x^2))"
    },
    {
      "id": "moving-average-latest",
      "label": "Latest moving average",
      "category": "signal-conditioning",
      "operation": "moving_average_latest",
      "inputs": [
        {
          "key": "values",
          "label": "Samples",
          "unit": "",
          "type": "array",
          "minItems": 1
        },
        {
          "key": "windowSize",
          "label": "Window size",
          "unit": "samples",
          "type": "number",
          "min": 1
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "mean(last W)"
    },
    {
      "id": "exponential-smoothing-alpha",
      "label": "Exponential smoothing alpha",
      "category": "signal-conditioning",
      "operation": "smoothing_alpha",
      "inputs": [
        {
          "key": "sampleIntervalSeconds",
          "label": "Sample interval",
          "unit": "s",
          "type": "number",
          "min": 0
        },
        {
          "key": "timeConstantSeconds",
          "label": "Time constant",
          "unit": "s",
          "type": "number",
          "min": 1e-12
        }
      ],
      "output": {
        "unit": "0-1"
      },
      "formula": "alpha=dt/(tau+dt)"
    },
    {
      "id": "linear-interpolation",
      "label": "Linear interpolation",
      "category": "signal-conditioning",
      "operation": "linear_interpolation",
      "inputs": [
        {
          "key": "x0",
          "label": "x0",
          "unit": "",
          "type": "number"
        },
        {
          "key": "y0",
          "label": "y0",
          "unit": "",
          "type": "number"
        },
        {
          "key": "x1",
          "label": "x1",
          "unit": "",
          "type": "number"
        },
        {
          "key": "y1",
          "label": "y1",
          "unit": "",
          "type": "number"
        },
        {
          "key": "x",
          "label": "x",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "y=y0+(x-x0)*(y1-y0)/(x1-x0)"
    },
    {
      "id": "trapezoid-area",
      "label": "Trapezoid area",
      "category": "signal-conditioning",
      "operation": "trapezoid_area",
      "inputs": [
        {
          "key": "x0",
          "label": "x0",
          "unit": "",
          "type": "number"
        },
        {
          "key": "y0",
          "label": "y0",
          "unit": "",
          "type": "number"
        },
        {
          "key": "x1",
          "label": "x1",
          "unit": "",
          "type": "number"
        },
        {
          "key": "y1",
          "label": "y1",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "unit*x"
      },
      "formula": "A=(x1-x0)*(y0+y1)/2"
    },
    {
      "id": "finite-difference",
      "label": "Finite-difference derivative",
      "category": "signal-conditioning",
      "operation": "finite_difference",
      "inputs": [
        {
          "key": "x0",
          "label": "x0",
          "unit": "",
          "type": "number"
        },
        {
          "key": "y0",
          "label": "y0",
          "unit": "",
          "type": "number"
        },
        {
          "key": "x1",
          "label": "x1",
          "unit": "",
          "type": "number"
        },
        {
          "key": "y1",
          "label": "y1",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "units/x"
      },
      "formula": "dy/dx=(y1-y0)/(x1-x0)"
    },
    {
      "id": "baseline-corrected-value",
      "label": "Baseline-corrected value",
      "category": "signal-conditioning",
      "operation": "baseline_corrected",
      "inputs": [
        {
          "key": "value",
          "label": "Value",
          "unit": "",
          "type": "number"
        },
        {
          "key": "baseline",
          "label": "Baseline",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "units"
      },
      "formula": "value-baseline"
    },
    {
      "id": "celsius-to-fahrenheit",
      "label": "Celsius to Fahrenheit",
      "category": "unit-normalization",
      "operation": "c_to_f",
      "inputs": [
        {
          "key": "celsius",
          "label": "Celsius",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "\u00b0F"
      },
      "formula": "Celsius to Fahrenheit"
    },
    {
      "id": "fahrenheit-to-celsius",
      "label": "Fahrenheit to Celsius",
      "category": "unit-normalization",
      "operation": "f_to_c",
      "inputs": [
        {
          "key": "fahrenheit",
          "label": "Fahrenheit",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "\u00b0C"
      },
      "formula": "Fahrenheit to Celsius"
    },
    {
      "id": "celsius-to-kelvin",
      "label": "Celsius to Kelvin",
      "category": "unit-normalization",
      "operation": "c_to_k",
      "inputs": [
        {
          "key": "celsius",
          "label": "Celsius",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "K"
      },
      "formula": "Celsius to Kelvin"
    },
    {
      "id": "kelvin-to-celsius",
      "label": "Kelvin to Celsius",
      "category": "unit-normalization",
      "operation": "k_to_c",
      "inputs": [
        {
          "key": "kelvin",
          "label": "Kelvin",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "\u00b0C"
      },
      "formula": "Kelvin to Celsius"
    },
    {
      "id": "pascal-to-kilopascal",
      "label": "Pascal to kilopascal",
      "category": "unit-normalization",
      "operation": "pa_to_kpa",
      "inputs": [
        {
          "key": "pascal",
          "label": "Pressure",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "kPa"
      },
      "formula": "Pascal to kilopascal"
    },
    {
      "id": "milliliter-to-liter",
      "label": "Milliliter to liter",
      "category": "unit-normalization",
      "operation": "ml_to_l",
      "inputs": [
        {
          "key": "milliliter",
          "label": "Volume",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "L"
      },
      "formula": "Milliliter to liter"
    },
    {
      "id": "milligram-to-gram",
      "label": "Milligram to gram",
      "category": "unit-normalization",
      "operation": "mg_to_g",
      "inputs": [
        {
          "key": "milligram",
          "label": "Mass",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "g"
      },
      "formula": "Milligram to gram"
    },
    {
      "id": "microgram-to-milligram",
      "label": "Microgram to milligram",
      "category": "unit-normalization",
      "operation": "ug_to_mg",
      "inputs": [
        {
          "key": "microgram",
          "label": "Mass",
          "unit": "",
          "type": "number"
        }
      ],
      "output": {
        "unit": "mg"
      },
      "formula": "Microgram to milligram"
    },
    {
      "id": "elapsed-seconds",
      "label": "Elapsed seconds",
      "category": "temporal-normalization",
      "operation": "elapsed_seconds",
      "inputs": [
        {
          "key": "startEpochSeconds",
          "label": "Start epoch",
          "unit": "s",
          "type": "number"
        },
        {
          "key": "endEpochSeconds",
          "label": "End epoch",
          "unit": "s",
          "type": "number"
        }
      ],
      "output": {
        "unit": "s"
      },
      "formula": "end-start"
    },
    {
      "id": "timezone-adjusted-epoch",
      "label": "Timezone-adjusted epoch",
      "category": "temporal-normalization",
      "operation": "timezone_adjusted_epoch",
      "inputs": [
        {
          "key": "epochSeconds",
          "label": "Epoch",
          "unit": "s",
          "type": "number"
        },
        {
          "key": "offsetMinutes",
          "label": "Offset",
          "unit": "min",
          "type": "number"
        }
      ],
      "output": {
        "unit": "s"
      },
      "formula": "epoch+offset*60"
    },
    {
      "id": "events-per-hour",
      "label": "Events per hour",
      "category": "temporal-normalization",

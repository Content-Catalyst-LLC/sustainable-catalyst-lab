{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design matrix v0.30.1",
  "type": "object",
  "required": [
    "schema",
    "id",
    "studyId",
    "rows",
    "matrixHash"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-design-matrix/0.30.1"
    },
    "id": {
      "type": "string"
    },
    "studyId": {
      "type": "string"
    },
    "rows": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2000
    },
    "matrixHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Secret Record v0.39.1",
  "type": "object",
  "required": [
    "schema",
    "id",
    "institutionId",
    "name",
    "version",
    "keyId",
    "status",
    "valueDigest",
    "createdBy",
    "createdAt",
    "valueStored"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-secret-record/0.39.1"
    },
    "id": {
      "type": "string"
    },
    "institutionId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "keyId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "superseded",
        "revoked"
      ]
    },
    "valueDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "rotatedFrom": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "valueStored": {
      "const": true
    }
  },
  "additionalProperties": true
}

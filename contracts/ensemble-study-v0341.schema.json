{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/ensemble-study-v0341.schema.json",
  "title": "Sustainable Catalyst Lab Ensemble Study v0.34.1",
  "type": "object",
  "required": ["schema", "version", "id", "projectId", "members", "variables", "design", "output", "definitionHash"],
  "properties": {
    "schema": {"const": "sc-lab-ensemble-study/0.34.1"},
    "version": {"const": "0.34.1"},
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,179}$"},
    "title": {"type": "string", "minLength": 1, "maxLength": 300},
    "projectId": {"type": "string", "minLength": 1, "maxLength": 180},
    "members": {
      "type": "array", "minItems": 1, "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["memberIndex", "modelId", "modelVersion", "modelHash", "methodId", "normalizedWeight"],
        "properties": {
          "memberIndex": {"type": "integer", "minimum": 0},
          "modelId": {"type": "string"},
          "modelVersion": {"type": "string"},
          "modelHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "environmentLockHash": {"type": ["string", "null"]},
          "methodId": {"type": "string"},
          "weight": {"type": "number", "exclusiveMinimum": 0},
          "normalizedWeight": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
        },
        "additionalProperties": true
      }
    },
    "variables": {
      "type": "array", "minItems": 1, "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["name", "path", "distribution"],
        "properties": {
          "name": {"type": "string"},
          "path": {"type": "string"},
          "distribution": {"enum": ["uniform", "normal", "lognormal", "triangular", "discrete"]}
        },
        "additionalProperties": true
      }
    },
    "design": {
      "type": "object",
      "required": ["method", "samples", "seed", "evaluationCount"],
      "properties": {
        "method": {"enum": ["monte-carlo", "latin-hypercube", "sobol", "saltelli-sobol"]},
        "samples": {"type": "integer", "minimum": 4, "maximum": 10000},
        "seed": {"type": "integer"},
        "evaluationCount": {"type": "integer", "minimum": 4, "maximum": 200000}
      }
    },
    "output": {
      "type": "object",
      "required": ["path", "label"],
      "properties": {"path": {"type": "string", "minLength": 1}, "label": {"type": "string"}, "unit": {"type": ["string", "null"]}}
    },
    "definitionHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": true
}

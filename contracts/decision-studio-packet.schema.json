{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/sc-decision-studio-analysis-packet-2.0.schema.json",
  "title": "Sustainable Catalyst Lab Decision Studio Report Packet",
  "type": "object",
  "required": ["packetType", "schemaVersion", "origin", "createdAt", "report", "analyses", "charts", "scenes", "tables", "audit"],
  "properties": {
    "packetType": { "enum": ["scientific-analysis", "scientific-report"] },
    "schemaVersion": { "const": "2.0" },
    "origin": {
      "type": "object",
      "required": ["application", "version"],
      "properties": {
        "application": { "const": "Sustainable Catalyst Lab" },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "createdAt": { "type": "string" },
    "project": { "type": ["object", "null"] },
    "report": { "type": "object" },
    "analysis": { "type": "object" },
    "analyses": { "type": "array", "minItems": 1, "maxItems": 12 },
    "charts": { "type": "array" },
    "scenes": { "type": "array" },
    "tables": { "type": "array" },
    "claims": { "type": "array" },
    "assumptions": { "type": "array" },
    "uncertainties": { "type": "array" },
    "warnings": { "type": "array" },
    "evidence": { "type": "array" },
    "sources": { "type": "array" },
    "codeRuntimes": { "type": "array" },
    "validationRecords": { "type": "array" },
    "audit": { "type": "object" }
  },
  "additionalProperties": true
}

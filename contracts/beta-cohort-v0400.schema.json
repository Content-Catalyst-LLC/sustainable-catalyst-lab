{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Institutional Beta Cohort v0.40.0",
  "type": "object",
  "required": [
    "id",
    "name",
    "institutionId",
    "owner",
    "status",
    "createdAt",
    "recordHash"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "institutionId": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "planned",
        "active",
        "paused",
        "closed"
      ]
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "recordHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}

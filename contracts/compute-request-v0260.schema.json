{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/compute-request-v0260.schema.json",
  "title": "Sustainable Catalyst Python Compute Request",
  "type": "object",
  "required": [
    "method",
    "inputs"
  ],
  "additionalProperties": false,
  "properties": {
    "method": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$",
      "maxLength": 128
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "inputs": {
      "type": "object"
    },
    "units": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "parameters": {
      "type": "object"
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requested_outputs": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string"
      }
    },
    "random_seed": {
      "type": [
        "integer",
        "null"
      ]
    },
    "execution_target": {
      "enum": [
        "automatic",
        "python-core"
      ]
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "precisionProfile": {
          "enum": [
            "fast",
            "balanced",
            "strict",
            "diagnostic"
          ]
        },
        "solverPolicy": {
          "enum": [
            "automatic",
            "recommended",
            "manual"
          ]
        },
        "requestedSolver": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "unitPolicy": {
          "enum": [
            "off",
            "warn",
            "strict"
          ]
        },
        "conditionThreshold": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0
        },
        "illConditionedPolicy": {
          "enum": [
            "reject",
            "warn",
            "least-squares"
          ]
        },
        "referenceComparison": {
          "type": "boolean"
        },
        "uncertaintyStandard": {
          "enum": [
            "method-default",
            "GUM-inspired",
            "Monte-Carlo",
            "bootstrap"
          ]
        },
        "absoluteTolerance": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 1e-15,
          "maximum": 0.01
        },
        "relativeTolerance": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 1e-15,
          "maximum": 0.01
        }
      }
    }
  }
}

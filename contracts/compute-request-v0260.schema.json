{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/compute-request-v0260.schema.json",
  "title": "Sustainable Catalyst Python Compute Request",
  "type": "object",
  "required": [
    "method",
    "inputs"
  ],
  "additionalProperties": false,
  "properties": {
    "method": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$",
      "maxLength": 128
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "inputs": {
      "type": "object"
    },
    "units": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "parameters": {
      "type": "object"
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requested_outputs": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string"
      }
    },
    "random_seed": {
      "type": [
        "integer",
        "null"
      ]
    },
    "execution_target": {
      "enum": [
        "automatic",
        "python-core"
      ]
    }
  }
}

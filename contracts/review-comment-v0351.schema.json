{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lab Review Comment v0.35.1",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "workspaceId",
    "threadId",
    "actorId",
    "body",
    "status",
    "commentHash",
    "createdAt"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-review-comment/0.35.1"
    },
    "version": {
      "const": "0.35.1"
    },
    "id": {
      "type": "string"
    },
    "workspaceId": {
      "type": "string"
    },
    "threadId": {
      "type": "string"
    },
    "parentCommentId": {
      "type": [
        "string",
        "null"
      ]
    },
    "actorId": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "withdrawn"
      ]
    },
    "commentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "createdAt": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sustainable Catalyst Compute Provenance",
  "type": "object",
  "required": [
    "run_id",
    "method",
    "method_version",
    "service_version",
    "input_sha256",
    "result_sha256",
    "packages"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "method": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    },
    "service_version": {
      "type": "string"
    },
    "executed_at": {
      "type": "string"
    },
    "duration_ms": {
      "type": "number"
    },
    "python_version": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "packages": {
      "type": "object"
    },
    "input_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "result_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "random_seed": {},
    "worker_type": {
      "type": "string"
    },
    "authentication_mode": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    }
  }
}

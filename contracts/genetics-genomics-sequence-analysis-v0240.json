{
  "schema": "sc-lab-genetics-genomics-sequence-analysis/1.0",
  "version": "0.24.0",
  "title": "Genetics, Genomics, and Sequence Analysis",
  "categories": [
    {
      "id": "sequence-composition",
      "label": "Sequence composition",
      "description": "Length, base composition, ambiguity, skew, and information content."
    },
    {
      "id": "sequence-transformations",
      "label": "Sequence transformations",
      "description": "Normalization, complements, transcription, and base inventories."
    },
    {
      "id": "coding-translation",
      "label": "Coding and translation",
      "description": "Codons, translation, start/stop codons, and open reading frames."
    },
    {
      "id": "motifs-kmers",
      "label": "Motifs and k-mers",
      "description": "Motif hits, k-mer spectra, frequencies, and palindromic patterns."
    },
    {
      "id": "alignment-comparison",
      "label": "Alignment and comparison",
      "description": "Distance, identity, similarity, and prefix comparisons."
    },
    {
      "id": "variants",
      "label": "Variant calculations",
      "description": "Allele fractions, balance, density, substitution class, and quality."
    },
    {
      "id": "population-genetics",
      "label": "Population genetics",
      "description": "Allele frequencies, heterozygosity, equilibrium, diversity, and differentiation."
    },
    {
      "id": "data-quality",
      "label": "Sequence data quality",
      "description": "Valid bases, assembly N50, length statistics, metadata coverage, and duplicate identifiers."
    }
  ],
  "methods": [
    {
      "id": "sequence-length",
      "label": "Sequence length",
      "category": "sequence-composition",
      "operation": "sequence_length",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "bases"
      },
      "formula": "L = number of normalized symbols",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "gc-content",
      "label": "GC content",
      "category": "sequence-composition",
      "operation": "gc_content",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "GC = (G+C)/(A+C+G+T) \u00d7 100",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "at-content",
      "label": "AT content",
      "category": "sequence-composition",
      "operation": "at_content",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "AT = (A+T)/(A+C+G+T) \u00d7 100",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "ambiguous-base-percent",
      "label": "Ambiguous-base percentage",
      "category": "sequence-composition",
      "operation": "ambiguous_percent",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "ambiguous / total \u00d7 100",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "gc-skew",
      "label": "GC skew",
      "category": "sequence-composition",
      "operation": "gc_skew",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "ratio"
      },
      "formula": "(G\u2212C)/(G+C)",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "sequence-entropy",
      "label": "Sequence Shannon entropy",
      "category": "sequence-composition",
      "operation": "sequence_entropy",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "bits/symbol"
      },
      "formula": "\u2212\u03a3pi log2(pi)",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "normalize-sequence",
      "label": "Normalize sequence",
      "category": "sequence-transformations",
      "operation": "normalize_sequence",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "sequence"
      },
      "formula": "uppercase and remove whitespace",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "complement",
      "label": "DNA complement",
      "category": "sequence-transformations",
      "operation": "complement",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "sequence"
      },
      "formula": "A\u2194T, C\u2194G",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "reverse-complement",
      "label": "DNA reverse complement",
      "category": "sequence-transformations",
      "operation": "reverse_complement",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "sequence"
      },
      "formula": "reverse(complement(sequence))",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "transcribe-dna-to-rna",
      "label": "Transcribe DNA to RNA",
      "category": "sequence-transformations",
      "operation": "transcribe",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "sequence"
      },
      "formula": "T \u2192 U",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "reverse-transcribe-rna-to-dna",
      "label": "Reverse transcribe RNA to DNA",
      "category": "sequence-transformations",
      "operation": "reverse_transcribe",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "sequence"
      },
      "formula": "U \u2192 T",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "base-counts",
      "label": "Base counts",
      "category": "sequence-transformations",
      "operation": "base_counts",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "counts"
      },
      "formula": "counts of A,C,G,T,U,N,other",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "translate-sequence",
      "label": "Translate nucleotide sequence",
      "category": "coding-translation",
      "operation": "translate",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "frame",
          "label": "Reading frame",
          "unit": "0\u20132",
          "type": "integer",
          "min": 0,
          "max": 2
        }
      ],
      "output": {
        "unit": "amino-acid sequence"
      },
      "formula": "standard genetic code",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "codon-count",
      "label": "Complete codon count",
      "category": "coding-translation",
      "operation": "codon_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "frame",
          "label": "Reading frame",
          "unit": "0\u20132",
          "type": "integer",
          "min": 0,
          "max": 2
        }
      ],
      "output": {
        "unit": "codons"
      },
      "formula": "floor((L\u2212frame)/3)",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "start-codon-count",
      "label": "Start codon count",
      "category": "coding-translation",
      "operation": "start_codon_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "codons"
      },
      "formula": "count(ATG)",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "stop-codon-count",
      "label": "Stop codon count",
      "category": "coding-translation",
      "operation": "stop_codon_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "codons"
      },
      "formula": "count(TAA,TAG,TGA)",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "longest-orf-length",
      "label": "Longest ORF length",
      "category": "coding-translation",
      "operation": "longest_orf_length",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "bases"
      },
      "formula": "longest ATG-to-stop ORF across three forward frames",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "orf-count",
      "label": "Forward ORF count",
      "category": "coding-translation",
      "operation": "orf_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "ORFs"
      },
      "formula": "ATG-to-stop ORFs across three forward frames",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "motif-count",
      "label": "Motif count",
      "category": "motifs-kmers",
      "operation": "motif_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "motif",
          "label": "Motif",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "hits"
      },
      "formula": "overlapping exact hits",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "motif-positions",
      "label": "Motif positions",
      "category": "motifs-kmers",
      "operation": "motif_positions",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "motif",
          "label": "Motif",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "0-based positions"
      },
      "formula": "overlapping exact hit positions",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "kmer-count",
      "label": "K-mer window count",
      "category": "motifs-kmers",
      "operation": "kmer_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "k",
          "label": "K",
          "unit": "bases",
          "type": "integer",
          "min": 1
        }
      ],
      "output": {
        "unit": "windows"
      },
      "formula": "max(0,L\u2212k+1)",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "unique-kmer-count",
      "label": "Unique k-mer count",
      "category": "motifs-kmers",
      "operation": "unique_kmer_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "k",
          "label": "K",
          "unit": "bases",
          "type": "integer",
          "min": 1
        }
      ],
      "output": {
        "unit": "unique k-mers"
      },
      "formula": "cardinality of k-mer set",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "kmer-frequency",
      "label": "K-mer frequency",
      "category": "motifs-kmers",
      "operation": "kmer_frequency",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "kmer",
          "label": "K-mer",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "matching k-mer windows / all windows \u00d7 100",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "palindromic-kmer-count",
      "label": "Reverse-complement palindromic k-mers",
      "category": "motifs-kmers",
      "operation": "palindromic_kmer_count",
      "inputs": [
        {
          "key": "sequence",
          "label": "Sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "k",
          "label": "K",
          "unit": "bases",
          "type": "integer",
          "min": 1
        }
      ],
      "output": {
        "unit": "windows"

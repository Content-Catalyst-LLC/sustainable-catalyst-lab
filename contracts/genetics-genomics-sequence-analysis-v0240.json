    },
    {
      "id": "percent-identity",
      "label": "Position-wise percent identity",
      "category": "alignment-comparison",
      "operation": "percent_identity",
      "inputs": [
        {
          "key": "reference",
          "label": "Reference sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "query",
          "label": "Query sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "matches / max length \u00d7 100",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "simple-alignment-score",
      "label": "Simple alignment score",
      "category": "alignment-comparison",
      "operation": "simple_alignment_score",
      "inputs": [
        {
          "key": "reference",
          "label": "Reference sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "query",
          "label": "Query sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "matchScore",
          "label": "Match score",
          "unit": "points",
          "type": "number"
        },
        {
          "key": "mismatchScore",
          "label": "Mismatch score",
          "unit": "points",
          "type": "number"
        },
        {
          "key": "gapScore",
          "label": "Gap score",
          "unit": "points",
          "type": "number"
        }
      ],
      "output": {
        "unit": "points"
      },
      "formula": "position-wise match/mismatch/gap score",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "jaccard-kmers",

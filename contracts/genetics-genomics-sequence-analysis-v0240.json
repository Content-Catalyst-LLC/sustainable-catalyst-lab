    },
    {
      "id": "reference-allele-frequency",
      "label": "Reference allele frequency",
      "category": "variants",
      "operation": "reference_allele_frequency",
      "inputs": [
        {
          "key": "referenceDepth",
          "label": "Reference depth",
          "unit": "reads",
          "type": "number",
          "min": 0
        },
        {
          "key": "readDepth",
          "label": "Read depth",
          "unit": "reads",
          "type": "number",
          "min": 1e-06
        }
      ],
      "output": {
        "unit": "%"
      },
      "formula": "reference depth / read depth \u00d7 100",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {

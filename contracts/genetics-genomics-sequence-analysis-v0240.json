        {
          "key": "query",
          "label": "Query sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "differences"
      },
      "formula": "position mismatches for equal lengths",
      "responsibleUse": "Research and education only; not for clinical interpretation, diagnosis, treatment, or regulated variant reporting."
    },
    {
      "id": "levenshtein-distance",
      "label": "Levenshtein edit distance",
      "category": "alignment-comparison",
      "operation": "levenshtein_distance",
      "inputs": [
        {
          "key": "reference",
          "label": "Reference sequence",
          "unit": "bases",
          "type": "sequence"
        },
        {
          "key": "query",
          "label": "Query sequence",
          "unit": "bases",
          "type": "sequence"
        }
      ],
      "output": {
        "unit": "edits"

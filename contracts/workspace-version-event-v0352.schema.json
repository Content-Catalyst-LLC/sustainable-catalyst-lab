{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/workspace-version-event-v0352.schema.json",
  "title": "Workspace Version Event v0.35.2",
  "type": "object",
  "required": [
    "schema",
    "version",
    "sequence",
    "workspaceId",
    "eventType",
    "actorId",
    "details",
    "eventHash",
    "createdAt"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-workspace-version-event/0.35.2"
    },
    "version": {
      "const": "0.35.2"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "actorId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,179}$"
    },
    "details": {
      "type": "object"
    },
    "eventHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "createdAt": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

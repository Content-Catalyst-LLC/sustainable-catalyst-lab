{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Service Credential v0.39.1",
  "type": "object",
  "required": [
    "schema",
    "id",
    "institutionId",
    "principalId",
    "label",
    "tokenPrefix",
    "scopes",
    "status",
    "issuedBy",
    "issuedAt",
    "expiresAt"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-service-credential/0.39.1"
    },
    "id": {
      "type": "string"
    },
    "institutionId": {
      "type": "string"
    },
    "principalId": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "tokenPrefix": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "active",
        "revoked"
      ]
    },
    "issuedBy": {
      "type": "string"
    },
    "issuedAt": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

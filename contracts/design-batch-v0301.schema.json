{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design batch v0.30.1",
  "type": "object",
  "required": [
    "schema",
    "id",
    "matrixId",
    "methodId",
    "jobs",
    "batchHash"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-design-batch/0.30.1"
    },
    "id": {
      "type": "string"
    },
    "matrixId": {
      "type": "string"
    },
    "methodId": {
      "type": "string"
    },
    "jobs": {
      "type": "array",
      "maxItems": 2000
    },
    "batchHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
        },
        {
          "key": "generatedTonnes",
          "label": "Generated waste",
          "unit": "tonnes/yr",
          "default": 210000
        }
      ],
      "outputs": {
        "recyclingFraction": {
          "expression": "recycledTonnes/generatedTonnes",
          "unit": "1"
        }

{
  "schema": "sc-lab-circular-economy-industrial-ecology-catalog/1.0",
  "version": "0.16.0",
  "methodCount": 48,
  "categories": [
    "Material flow & resource accounting",
    "Circular products & business models",
    "Waste prevention & resource recovery",
    "Industrial symbiosis & eco-industrial networks",
    "Lifecycle & footprint accounting",
    "Circular transition & resilience"
  ],
  "methods": [
    {
      "id": "ce.direct_material_input",
      "category": "Material flow & resource accounting",
      "title": "Direct material input",
      "equation": "DMI = domestic extraction + imports",
      "inputs": [
        {
          "key": "domesticExtractionTonnes",
          "label": "Domestic extraction",
          "unit": "tonnes/yr",
          "default": 2400000
        },
        {
          "key": "importsTonnes",
          "label": "Material imports",
          "unit": "tonnes/yr",
          "default": 1100000
        }
      ],
      "outputs": {
        "directMaterialInputTonnes": {
          "expression": "domesticExtractionTonnes+importsTonnes",
          "unit": "tonnes/yr"
        }
      },
      "assumptions": [
        "Domestic extraction and imports use the same material scope and year."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.domestic_material_consumption",
      "category": "Material flow & resource accounting",
      "title": "Domestic material consumption",
      "equation": "DMC = domestic extraction + imports − exports",
      "inputs": [
        {
          "key": "domesticExtractionTonnes",
          "label": "Domestic extraction",
          "unit": "tonnes/yr",
          "default": 2400000
        },
        {
          "key": "importsTonnes",
          "label": "Material imports",
          "unit": "tonnes/yr",
          "default": 1100000
        },
        {
          "key": "exportsTonnes",
          "label": "Material exports",
          "unit": "tonnes/yr",
          "default": 700000
        }
      ],
      "outputs": {
        "domesticMaterialConsumptionTonnes": {
          "expression": "domesticExtractionTonnes+importsTonnes-exportsTonnes",
          "unit": "tonnes/yr"
        }
      },
      "assumptions": [
        "Extraction, imports, and exports use a common accounting boundary."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.material_footprint_per_capita",
      "category": "Material flow & resource accounting",
      "title": "Material footprint per capita",
      "equation": "Footprint per capita = material footprint / population",
      "inputs": [
        {
          "key": "materialFootprintTonnes",
          "label": "Consumption-based material footprint",
          "unit": "tonnes/yr",
          "default": 3600000
        },
        {
          "key": "population",
          "label": "Population",
          "unit": "persons",
          "default": 300000
        }
      ],
      "outputs": {
        "materialFootprintTonnesPerCapita": {
          "expression": "materialFootprintTonnes/population",
          "unit": "tonnes/(person*yr)"
        }
      },
      "assumptions": [
        "Material footprint and population use the same reference year."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.material_intensity",
      "category": "Material flow & resource accounting",
      "title": "Material intensity of economic output",
      "equation": "Intensity = material use / GDP",
      "inputs": [
        {
          "key": "materialUseTonnes",
          "label": "Material use",
          "unit": "tonnes/yr",
          "default": 2800000
        },
        {
          "key": "gdpMillionUsd",
          "label": "Gross domestic product",
          "unit": "million USD/yr",
          "default": 48000
        }
      ],
      "outputs": {
        "materialIntensityTonnesPerMillionUsd": {
          "expression": "materialUseTonnes/gdpMillionUsd",
          "unit": "tonnes/million USD"
        }
      },
      "assumptions": [
        "GDP and material use describe the same economy and year."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.resource_productivity",
      "category": "Material flow & resource accounting",
      "title": "Resource productivity",
      "equation": "Productivity = GDP / material use",
      "inputs": [
        {
          "key": "gdpMillionUsd",
          "label": "Gross domestic product",
          "unit": "million USD/yr",
          "default": 48000
        },
        {
          "key": "materialUseTonnes",
          "label": "Material use",
          "unit": "tonnes/yr",
          "default": 2800000
        }
      ],
      "outputs": {
        "resourceProductivityUsdPerTonne": {
          "expression": "gdpMillionUsd*1000000/materialUseTonnes",
          "unit": "USD/tonne"
        }
      },
      "assumptions": [
        "GDP and material use describe the same economy and year."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.stock_accumulation",
      "category": "Material flow & resource accounting",
      "title": "Net addition to material stocks",
      "equation": "Stock addition = material inputs − material outputs",
      "inputs": [
        {
          "key": "materialInputsTonnes",
          "label": "Material inputs",
          "unit": "tonnes/yr",
          "default": 3500000
        },
        {
          "key": "materialOutputsTonnes",
          "label": "Material outputs",
          "unit": "tonnes/yr",
          "default": 2100000
        }
      ],
      "outputs": {
        "netStockAdditionTonnes": {
          "expression": "materialInputsTonnes-materialOutputsTonnes",
          "unit": "tonnes/yr"
        }
      },
      "assumptions": [
        "Inputs and outputs use compatible system boundaries."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.circular_material_use_rate",
      "category": "Material flow & resource accounting",
      "title": "Circular material use rate",
      "equation": "Circular use = secondary material / total material use",
      "inputs": [
        {
          "key": "secondaryMaterialTonnes",
          "label": "Secondary material use",
          "unit": "tonnes/yr",
          "default": 620000
        },
        {
          "key": "totalMaterialUseTonnes",
          "label": "Total material use",
          "unit": "tonnes/yr",
          "default": 2800000
        }
      ],
      "outputs": {
        "circularMaterialUseFraction": {
          "expression": "secondaryMaterialTonnes/totalMaterialUseTonnes",
          "unit": "1"
        }
      },
      "assumptions": [
        "Secondary and total material use share the same material boundary."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.mass_balance_gap",
      "category": "Material flow & resource accounting",
      "title": "Material-flow mass-balance gap",
      "equation": "Gap = |inputs − outputs − stock change|",
      "inputs": [
        {
          "key": "inputsTonnes",
          "label": "Total inputs",
          "unit": "tonnes/yr",
          "default": 3500000
        },
        {
          "key": "outputsTonnes",
          "label": "Total outputs",
          "unit": "tonnes/yr",
          "default": 2100000
        },
        {
          "key": "stockChangeTonnes",
          "label": "Net stock change",
          "unit": "tonnes/yr",
          "default": 1380000
        }
      ],
      "outputs": {
        "massBalanceGapTonnes": {
          "expression": "abs(inputsTonnes-outputsTonnes-stockChangeTonnes)",
          "unit": "tonnes/yr"
        }
      },
      "assumptions": [
        "All flow and stock terms use a consistent accounting boundary."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.product_life_extension",
      "category": "Circular products & business models",
      "title": "Product-life extension ratio",
      "equation": "Life extension = extended life / baseline life",
      "inputs": [
        {
          "key": "extendedLifeYears",
          "label": "Extended product life",
          "unit": "yr",
          "default": 12
        },
        {
          "key": "baselineLifeYears",
          "label": "Baseline product life",
          "unit": "yr",
          "default": 8
        }
      ],
      "outputs": {
        "lifeExtensionRatio": {
          "expression": "extendedLifeYears/baselineLifeYears",
          "unit": "1"
        }
      },
      "assumptions": [
        "Baseline and extended lives use the same service and maintenance assumptions."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.asset_utilization",
      "category": "Circular products & business models",
      "title": "Asset utilization rate",
      "equation": "Utilization = productive hours / available hours",
      "inputs": [
        {
          "key": "productiveHours",
          "label": "Productive use",
          "unit": "h/yr",
          "default": 3200
        },
        {
          "key": "availableHours",
          "label": "Available operating time",
          "unit": "h/yr",
          "default": 8760
        }
      ],
      "outputs": {
        "utilizationFraction": {
          "expression": "productiveHours/availableHours",
          "unit": "1"
        }
      },
      "assumptions": [
        "Available time excludes declared maintenance downtime only when documented."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.repair_rate",
      "category": "Circular products & business models",
      "title": "Repair completion rate",
      "equation": "Repair rate = repaired units / failed units",
      "inputs": [
        {
          "key": "repairedUnits",
          "label": "Successfully repaired units",
          "unit": "units/yr",
          "default": 8200
        },
        {
          "key": "failedUnits",
          "label": "Failed units presented",
          "unit": "units/yr",
          "default": 10000
        }
      ],
      "outputs": {
        "repairFraction": {
          "expression": "repairedUnits/failedUnits",
          "unit": "1"
        }
      },
      "assumptions": [
        "Failed and repaired units use the same product population and period."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.reuse_rate",
      "category": "Circular products & business models",
      "title": "Product reuse rate",
      "equation": "Reuse rate = reused units / collected units",
      "inputs": [
        {
          "key": "reusedUnits",
          "label": "Units prepared for reuse",
          "unit": "units/yr",
          "default": 4800
        },
        {
          "key": "collectedUnits",
          "label": "Collected units",
          "unit": "units/yr",
          "default": 12000
        }
      ],
      "outputs": {
        "reuseFraction": {
          "expression": "reusedUnits/collectedUnits",
          "unit": "1"
        }
      },
      "assumptions": [
        "Reuse and collection counts use a common acceptance definition."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.remanufacturing_yield",
      "category": "Circular products & business models",
      "title": "Remanufacturing mass yield",
      "equation": "Yield = remanufactured output mass / returned core mass",
      "inputs": [
        {
          "key": "remanufacturedOutputKg",
          "label": "Remanufactured output",
          "unit": "kg/yr",
          "default": 840000
        },
        {
          "key": "returnedCoreKg",
          "label": "Returned core input",
          "unit": "kg/yr",
          "default": 1000000
        }
      ],
      "outputs": {
        "remanufacturingYield": {
          "expression": "remanufacturedOutputKg/returnedCoreKg",
          "unit": "1"
        }
      },
      "assumptions": [
        "Returned cores and remanufactured output use the same product scope."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.service_model_utilization_gain",
      "category": "Circular products & business models",
      "title": "Product-as-a-service utilization gain",
      "equation": "Gain = new utilization / baseline utilization − 1",
      "inputs": [
        {
          "key": "newUtilizationFraction",
          "label": "Service-model utilization",
          "unit": "1",
          "default": 0.62
        },
        {
          "key": "baselineUtilizationFraction",
          "label": "Baseline utilization",
          "unit": "1",
          "default": 0.38
        }
      ],
      "outputs": {
        "utilizationGainFraction": {
          "expression": "newUtilizationFraction/baselineUtilizationFraction-1",
          "unit": "1"
        }
      },
      "assumptions": [
        "Utilization is measured using the same service-output definition."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.modularity_recoverability",
      "category": "Circular products & business models",
      "title": "Weighted modularity and recoverability index",
      "equation": "Index = weighted modularity + disassembly + recovery",
      "inputs": [
        {
          "key": "modularityScore",
          "label": "Modularity score",
          "unit": "0-100",
          "default": 78
        },
        {
          "key": "modularityWeight",
          "label": "Modularity weight",
          "unit": "1",
          "default": 0.35
        },
        {
          "key": "disassemblyScore",
          "label": "Disassembly score",
          "unit": "0-100",
          "default": 72
        },
        {
          "key": "disassemblyWeight",
          "label": "Disassembly weight",
          "unit": "1",
          "default": 0.3
        },
        {
          "key": "recoveryScore",
          "label": "Material recovery score",
          "unit": "0-100",
          "default": 82
        },
        {
          "key": "recoveryWeight",
          "label": "Recovery weight",
          "unit": "1",
          "default": 0.35
        }
      ],
      "outputs": {
        "recoverabilityIndex": {
          "expression": "(modularityScore*modularityWeight+disassemblyScore*disassemblyWeight+recoveryScore*recoveryWeight)/(modularityWeight+disassemblyWeight+recoveryWeight)",
          "unit": "0-100"
        }
      },
      "assumptions": [
        "Scores share a common scale and weights are explicit design assumptions."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.circular_revenue_share",
      "category": "Circular products & business models",
      "title": "Circular revenue share",
      "equation": "Share = circular revenue / total revenue",
      "inputs": [
        {
          "key": "circularRevenueUsd",
          "label": "Circular-model revenue",
          "unit": "USD/yr",
          "default": 42000000
        },
        {
          "key": "totalRevenueUsd",
          "label": "Total revenue",
          "unit": "USD/yr",
          "default": 150000000
        }
      ],
      "outputs": {
        "circularRevenueFraction": {
          "expression": "circularRevenueUsd/totalRevenueUsd",
          "unit": "1"
        }
      },
      "assumptions": [
        "Revenue categories are mutually exclusive and consistently classified."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.waste_prevention_rate",
      "category": "Waste prevention & resource recovery",
      "title": "Waste prevention rate",
      "equation": "Prevention = avoided waste / baseline waste",
      "inputs": [
        {
          "key": "avoidedWasteTonnes",
          "label": "Avoided waste",
          "unit": "tonnes/yr",
          "default": 32000
        },
        {
          "key": "baselineWasteTonnes",
          "label": "Baseline waste",
          "unit": "tonnes/yr",
          "default": 210000
        }
      ],
      "outputs": {
        "wastePreventionFraction": {
          "expression": "avoidedWasteTonnes/baselineWasteTonnes",
          "unit": "1"
        }
      },
      "assumptions": [
        "Avoided and baseline waste use the same stream and counterfactual."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.diversion_rate",
      "category": "Waste prevention & resource recovery",
      "title": "Waste diversion rate",
      "equation": "Diversion = diverted material / generated waste",
      "inputs": [
        {
          "key": "divertedTonnes",
          "label": "Diverted material",
          "unit": "tonnes/yr",
          "default": 128000
        },
        {
          "key": "generatedTonnes",
          "label": "Generated waste",
          "unit": "tonnes/yr",
          "default": 210000
        }
      ],
      "outputs": {
        "diversionFraction": {
          "expression": "divertedTonnes/generatedTonnes",
          "unit": "1"
        }

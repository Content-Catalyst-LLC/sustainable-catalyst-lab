    {
      "id": "ce.virgin_material_displacement",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Virgin material displacement",
      "equation": "Displacement = secondary input × substitution ratio",
      "inputs": [
        {
          "key": "secondaryInputTonnes",
          "label": "Secondary material input",
          "unit": "tonnes/yr",
          "default": 180000
        },
        {
          "key": "substitutionRatio",
          "label": "Virgin substitution ratio",
          "unit": "1",
          "default": 0.9
        }
      ],
      "outputs": {
        "virginMaterialDisplacedTonnes": {
          "expression": "secondaryInputTonnes*substitutionRatio",
          "unit": "tonnes/yr"
        }
      },
      "assumptions": [
        "Substitution ratio reflects functional equivalence and process yield."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.water_cascade_savings",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Industrial water-cascade savings",
      "equation": "Savings = reused water × avoided freshwater fraction",
      "inputs": [
        {
          "key": "reusedWaterM3",
          "label": "Water cascaded between facilities",
          "unit": "m^3/yr",
          "default": 2400000
        },
        {
          "key": "avoidedFreshwaterFraction",
          "label": "Avoided freshwater fraction",
          "unit": "1",
          "default": 0.95
        }
      ],
      "outputs": {
        "freshwaterSavingsM3": {
          "expression": "reusedWaterM3*avoidedFreshwaterFraction",
          "unit": "m^3/yr"
        }
      },
      "assumptions": [
        "Reused water meets the receiving process quality requirement."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.heat_cascade_recovery",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Recovered industrial heat",
      "equation": "Energy = mass flow × heat capacity × temperature drop × hours",
      "inputs": [
        {
          "key": "massFlowKgS",
          "label": "Transfer-fluid mass flow",
          "unit": "kg/s",
          "default": 12
        },
        {
          "key": "specificHeatJkgK",
          "label": "Specific heat capacity",
          "unit": "J/(kg*K)",
          "default": 4180
        },
        {
          "key": "temperatureDropK",
          "label": "Useful temperature drop",
          "unit": "K",
          "default": 18
        },
        {
          "key": "operatingHours",
          "label": "Annual operating hours",
          "unit": "h/yr",
          "default": 4200
        }
      ],
      "outputs": {
        "recoveredHeatMWh": {
          "expression": "massFlowKgS*specificHeatJkgK*temperatureDropK*operatingHours/1000000",
          "unit": "MWh/yr"
        }
      },
      "assumptions": [
        "Mass flow and temperature drop represent useful delivered heat."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.symbiosis_cost_savings",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Net industrial-symbiosis cost savings",
      "equation": "Savings = virgin cost avoided + disposal cost avoided − exchange operating cost",
      "inputs": [
        {
          "key": "virginCostAvoidedUsd",
          "label": "Virgin input cost avoided",
          "unit": "USD/yr",
          "default": 12000000
        },
        {
          "key": "disposalCostAvoidedUsd",
          "label": "Disposal cost avoided",
          "unit": "USD/yr",
          "default": 4800000
        },
        {
          "key": "exchangeOperatingCostUsd",
          "label": "Exchange operating cost",
          "unit": "USD/yr",
          "default": 5200000
        }
      ],
      "outputs": {
        "netSymbiosisSavingsUsd": {
          "expression": "virginCostAvoidedUsd+disposalCostAvoidedUsd-exchangeOperatingCostUsd",
          "unit": "USD/yr"
        }
      },
      "assumptions": [
        "Costs use the same price year and exclude transfers counted twice."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.avoided_disposal_cost",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Avoided disposal cost",
      "equation": "Avoided cost = diverted material × disposal cost",
      "inputs": [
        {
          "key": "divertedTonnes",
          "label": "Material diverted from disposal",
          "unit": "tonnes/yr",
          "default": 180000
        },
        {
          "key": "disposalCostUsdPerTonne",
          "label": "Disposal cost",
          "unit": "USD/tonne",
          "default": 72
        }
      ],
      "outputs": {
        "avoidedDisposalCostUsd": {
          "expression": "divertedTonnes*disposalCostUsdPerTonne",
          "unit": "USD/yr"
        }
      },
      "assumptions": [
        "Disposal cost includes the selected transport, tipping, and treatment components."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.symbiosis_network_density",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Directed symbiosis network density",
      "equation": "Density = exchanges / [participants × (participants − 1)]",
      "inputs": [
        {
          "key": "exchangeLinks",
          "label": "Directed exchange links",
          "unit": "links",
          "default": 48
        },
        {
          "key": "participantCount",
          "label": "Participating facilities",
          "unit": "facilities",
          "default": 12
        }
      ],
      "outputs": {
        "networkDensity": {
          "expression": "exchangeLinks/(participantCount*(participantCount-1))",
          "unit": "0-1"
        }
      },
      "assumptions": [
        "Network is directed and excludes self-links."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.symbiosis_network_redundancy",
      "category": "Industrial symbiosis & eco-industrial networks",
      "title": "Critical-exchange redundancy",
      "equation": "Redundancy = alternate exchange paths / critical exchanges",
      "inputs": [
        {
          "key": "alternateExchangePaths",
          "label": "Qualified alternate paths",
          "unit": "paths",
          "default": 18
        },
        {
          "key": "criticalExchanges",
          "label": "Critical exchanges",
          "unit": "exchanges",
          "default": 24
        }
      ],
      "outputs": {
        "networkRedundancy": {
          "expression": "alternateExchangePaths/criticalExchanges",
          "unit": "1"
        }
      },
      "assumptions": [
        "Alternate paths meet the same material quality and capacity requirements."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.embodied_carbon",
      "category": "Lifecycle & footprint accounting",
      "title": "Product embodied carbon",
      "equation": "Carbon = virgin mass × virgin factor + recycled mass × recycled factor",
      "inputs": [
        {
          "key": "virginMassKg",
          "label": "Virgin material mass",
          "unit": "kg",
          "default": 6000
        },
        {
          "key": "virginFactorKgCO2eKg",
          "label": "Virgin emissions factor",
          "unit": "kgCO2e/kg",
          "default": 2.8
        },
        {
          "key": "recycledMassKg",
          "label": "Recycled material mass",
          "unit": "kg",
          "default": 4000
        },
        {
          "key": "recycledFactorKgCO2eKg",
          "label": "Recycled emissions factor",
          "unit": "kgCO2e/kg",
          "default": 0.9
        }
      ],
      "outputs": {
        "embodiedCarbonKgCO2e": {
          "expression": "virginMassKg*virginFactorKgCO2eKg+recycledMassKg*recycledFactorKgCO2eKg",
          "unit": "kgCO2e"
        }
      },
      "assumptions": [
        "Factors use compatible lifecycle stages and allocation methods."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.lifecycle_carbon",
      "category": "Lifecycle & footprint accounting",
      "title": "Lifecycle greenhouse-gas impact",
      "equation": "Lifecycle carbon = manufacturing + use + transport + end of life − recovery credit",
      "inputs": [
        {
          "key": "manufacturingKgCO2e",
          "label": "Manufacturing impact",
          "unit": "kgCO2e",
          "default": 18000
        },
        {
          "key": "usePhaseKgCO2e",
          "label": "Use-phase impact",
          "unit": "kgCO2e",
          "default": 42000
        },
        {
          "key": "transportKgCO2e",
          "label": "Transport impact",
          "unit": "kgCO2e",
          "default": 3200
        },
        {
          "key": "endOfLifeKgCO2e",
          "label": "End-of-life impact",
          "unit": "kgCO2e",
          "default": 1800
        },
        {
          "key": "recoveryCreditKgCO2e",
          "label": "Recovery credit",
          "unit": "kgCO2e",
          "default": 6500
        }
      ],
      "outputs": {
        "lifecycleCarbonKgCO2e": {
          "expression": "manufacturingKgCO2e+usePhaseKgCO2e+transportKgCO2e+endOfLifeKgCO2e-recoveryCreditKgCO2e",
          "unit": "kgCO2e"
        }
      },
      "assumptions": [
        "Lifecycle stages and recovery credit follow a declared allocation method."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.recycled_content_savings",
      "category": "Lifecycle & footprint accounting",
      "title": "Recycled-content emissions savings",
      "equation": "Savings = recycled mass × (virgin factor − recycled factor)",
      "inputs": [
        {
          "key": "recycledMassKg",
          "label": "Recycled material mass",
          "unit": "kg",
          "default": 4000
        },
        {
          "key": "virginFactorKgCO2eKg",
          "label": "Virgin emissions factor",
          "unit": "kgCO2e/kg",
          "default": 2.8
        },
        {
          "key": "recycledFactorKgCO2eKg",
          "label": "Recycled emissions factor",
          "unit": "kgCO2e/kg",
          "default": 0.9
        }
      ],
      "outputs": {
        "emissionsSavingsKgCO2e": {
          "expression": "recycledMassKg*(virginFactorKgCO2eKg-recycledFactorKgCO2eKg)",
          "unit": "kgCO2e"
        }
      },
      "assumptions": [
        "Virgin and recycled factors provide equivalent material functionality."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.energy_payback",
      "category": "Lifecycle & footprint accounting",
      "title": "Circular intervention energy payback",
      "equation": "Payback = embodied energy / annual energy savings",
      "inputs": [
        {
          "key": "embodiedEnergyMWh",
          "label": "Embodied intervention energy",
          "unit": "MWh",
          "default": 2400
        },
        {
          "key": "annualEnergySavingsMWh",
          "label": "Annual energy savings",
          "unit": "MWh/yr",
          "default": 620
        }
      ],
      "outputs": {
        "energyPaybackYears": {
          "expression": "embodiedEnergyMWh/annualEnergySavingsMWh",
          "unit": "yr"
        }
      },
      "assumptions": [
        "Annual savings remain constant and use the same primary or final energy basis."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.water_footprint",
      "category": "Lifecycle & footprint accounting",
      "title": "Total water footprint",
      "equation": "Water footprint = blue + green + grey water",
      "inputs": [
        {
          "key": "blueWaterM3",
          "label": "Blue-water footprint",
          "unit": "m^3",
          "default": 1800
        },
        {
          "key": "greenWaterM3",
          "label": "Green-water footprint",
          "unit": "m^3",
          "default": 2600
        },
        {
          "key": "greyWaterM3",
          "label": "Grey-water footprint",
          "unit": "m^3",
          "default": 900
        }
      ],
      "outputs": {
        "totalWaterFootprintM3": {
          "expression": "blueWaterM3+greenWaterM3+greyWaterM3",
          "unit": "m^3"
        }
      },
      "assumptions": [
        "Water-footprint components use a common functional unit."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.end_of_life_recovery_credit",
      "category": "Lifecycle & footprint accounting",
      "title": "End-of-life recovery impact credit",
      "equation": "Credit = recovered mass × avoided impact factor",
      "inputs": [
        {
          "key": "recoveredMassKg",
          "label": "Recovered material mass",
          "unit": "kg",
          "default": 7200
        },
        {
          "key": "avoidedImpactKgCO2eKg",
          "label": "Avoided impact factor",
          "unit": "kgCO2e/kg",
          "default": 1.6
        }
      ],
      "outputs": {
        "recoveryCreditKgCO2e": {
          "expression": "recoveredMassKg*avoidedImpactKgCO2eKg",
          "unit": "kgCO2e"
        }
      },
      "assumptions": [
        "Credit follows the selected substitution and allocation approach."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.lifecycle_cost",
      "category": "Lifecycle & footprint accounting",
      "title": "Undiscounted lifecycle cost",
      "equation": "Cost = capital + annual operating × years + end of life − residual value",
      "inputs": [
        {
          "key": "capitalCostUsd",
          "label": "Capital cost",
          "unit": "USD",
          "default": 12000000
        },
        {
          "key": "annualOperatingCostUsd",
          "label": "Annual operating cost",
          "unit": "USD/yr",
          "default": 820000
        },
        {
          "key": "years",
          "label": "Analysis period",
          "unit": "yr",
          "default": 15
        },
        {
          "key": "endOfLifeCostUsd",
          "label": "End-of-life cost",
          "unit": "USD",
          "default": 900000
        },
        {
          "key": "residualValueUsd",
          "label": "Residual value",
          "unit": "USD",
          "default": 1800000
        }
      ],
      "outputs": {
        "lifecycleCostUsd": {
          "expression": "capitalCostUsd+annualOperatingCostUsd*years+endOfLifeCostUsd-residualValueUsd",
          "unit": "USD"
        }
      },
      "assumptions": [
        "This screening calculation is undiscounted; use NPV for time-value analysis."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.eco_efficiency",
      "category": "Lifecycle & footprint accounting",
      "title": "Economic eco-efficiency",
      "equation": "Eco-efficiency = economic value / lifecycle impact",
      "inputs": [
        {
          "key": "economicValueUsd",
          "label": "Economic value generated",
          "unit": "USD",
          "default": 45000000
        },
        {
          "key": "lifecycleImpactTonnesCO2e",
          "label": "Lifecycle impact",
          "unit": "tCO2e",
          "default": 18000
        }
      ],
      "outputs": {
        "ecoEfficiencyUsdPerTonneCO2e": {
          "expression": "economicValueUsd/lifecycleImpactTonnesCO2e",
          "unit": "USD/tCO2e"
        }
      },
      "assumptions": [
        "Economic value and environmental impact refer to the same functional system."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.circularity_score",
      "category": "Circular transition & resilience",
      "title": "Weighted circularity score",
      "equation": "Score = weighted materials + products + recovery + symbiosis",
      "inputs": [
        {
          "key": "materialScore",
          "label": "Material circularity score",
          "unit": "0-100",
          "default": 68
        },
        {
          "key": "materialWeight",
          "label": "Material weight",
          "unit": "1",
          "default": 0.3
        },
        {
          "key": "productScore",
          "label": "Product circularity score",
          "unit": "0-100",
          "default": 72
        },
        {
          "key": "productWeight",
          "label": "Product weight",
          "unit": "1",
          "default": 0.25
        },
        {
          "key": "recoveryScore",
          "label": "Recovery-system score",
          "unit": "0-100",
          "default": 76
        },
        {
          "key": "recoveryWeight",
          "label": "Recovery weight",
          "unit": "1",
          "default": 0.25
        },
        {
          "key": "symbiosisScore",
          "label": "Industrial symbiosis score",
          "unit": "0-100",
          "default": 64
        },
        {
          "key": "symbiosisWeight",
          "label": "Symbiosis weight",
          "unit": "1",
          "default": 0.2
        }
      ],
      "outputs": {
        "circularityScore": {
          "expression": "(materialScore*materialWeight+productScore*productWeight+recoveryScore*recoveryWeight+symbiosisScore*symbiosisWeight)/(materialWeight+productWeight+recoveryWeight+symbiosisWeight)",
          "unit": "0-100"
        }
      },
      "assumptions": [
        "Component scores use a common scale and weights are explicit governance choices."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.transition_gap",
      "category": "Circular transition & resilience",
      "title": "Circular transition gap",
      "equation": "Gap = target circularity − current circularity",
      "inputs": [
        {
          "key": "targetCircularityScore",
          "label": "Target circularity score",
          "unit": "0-100",
          "default": 85
        },
        {
          "key": "currentCircularityScore",
          "label": "Current circularity score",
          "unit": "0-100",
          "default": 68
        }
      ],
      "outputs": {
        "transitionGapPoints": {
          "expression": "targetCircularityScore-currentCircularityScore",
          "unit": "points"
        }
      },
      "assumptions": [
        "Target and current scores use the same indicator framework."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.circular_jobs",
      "category": "Circular transition & resilience",
      "title": "Circular-economy job creation estimate",
      "equation": "Jobs = investment × jobs per million",
      "inputs": [
        {
          "key": "investmentMillionUsd",
          "label": "Circular investment",
          "unit": "million USD",
          "default": 420
        },
        {
          "key": "jobsPerMillionUsd",
          "label": "Employment intensity",
          "unit": "jobs/million USD",
          "default": 7.5
        }
      ],
      "outputs": {
        "estimatedJobs": {
          "expression": "investmentMillionUsd*jobsPerMillionUsd",
          "unit": "jobs"
        }
      },
      "assumptions": [
        "Employment intensity is a transparent scenario assumption, not a forecast."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.import_dependency",
      "category": "Circular transition & resilience",
      "title": "Material import dependency",
      "equation": "Dependency = imports / (domestic extraction + imports)",
      "inputs": [
        {
          "key": "importsTonnes",
          "label": "Material imports",
          "unit": "tonnes/yr",
          "default": 1100000
        },
        {
          "key": "domesticExtractionTonnes",
          "label": "Domestic extraction",
          "unit": "tonnes/yr",
          "default": 2400000
        }
      ],
      "outputs": {
        "importDependencyFraction": {
          "expression": "importsTonnes/(domesticExtractionTonnes+importsTonnes)",
          "unit": "1"
        }
      },
      "assumptions": [
        "Imports and extraction use the same material categories and year."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.critical_material_recovery",
      "category": "Circular transition & resilience",
      "title": "Critical-material recovery coverage",
      "equation": "Coverage = recovered critical material / critical material demand",
      "inputs": [
        {
          "key": "recoveredCriticalTonnes",
          "label": "Recovered critical material",
          "unit": "tonnes/yr",
          "default": 14000
        },
        {
          "key": "criticalDemandTonnes",
          "label": "Critical material demand",
          "unit": "tonnes/yr",
          "default": 50000
        }
      ],
      "outputs": {
        "criticalRecoveryFraction": {
          "expression": "recoveredCriticalTonnes/criticalDemandTonnes",
          "unit": "1"
        }
      },
      "assumptions": [
        "Recovered material meets the quality required by the stated demand."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.supply_risk_reduction",
      "category": "Circular transition & resilience",
      "title": "Circular supply-risk reduction",
      "equation": "Reduced risk = baseline risk × recovery share × effectiveness",
      "inputs": [
        {
          "key": "baselineRiskScore",
          "label": "Baseline supply-risk score",
          "unit": "0-100",
          "default": 78
        },
        {
          "key": "recoveryShare",
          "label": "Circular supply share",
          "unit": "1",
          "default": 0.28
        },
        {
          "key": "riskReductionEffectiveness",
          "label": "Risk-reduction effectiveness",
          "unit": "1",
          "default": 0.65
        }
      ],
      "outputs": {
        "riskReductionPoints": {
          "expression": "baselineRiskScore*recoveryShare*riskReductionEffectiveness",
          "unit": "points"
        },
        "residualRiskScore": {
          "expression": "baselineRiskScore*(1-recoveryShare*riskReductionEffectiveness)",
          "unit": "0-100"
        }
      },
      "assumptions": [
        "Risk score and effectiveness are screening assumptions."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.scenario_npv",
      "category": "Circular transition & resilience",
      "title": "Circular transition net present value",
      "equation": "NPV = annual net benefit annuity − initial investment",
      "inputs": [
        {
          "key": "initialInvestmentUsd",
          "label": "Initial investment",
          "unit": "USD",
          "default": 180000000
        },
        {
          "key": "annualNetBenefitUsd",
          "label": "Annual net benefit",
          "unit": "USD/yr",
          "default": 28000000
        },
        {
          "key": "discountRate",
          "label": "Real discount rate",
          "unit": "1",
          "default": 0.04
        },
        {
          "key": "years",
          "label": "Analysis period",
          "unit": "yr",
          "default": 15
        }
      ],
      "outputs": {
        "netPresentValueUsd": {
          "expression": "annualNetBenefitUsd*(1-(1+discountRate)**(-years))/discountRate-initialInvestmentUsd",
          "unit": "USD"
        }
      },
      "assumptions": [
        "Annual net benefit and real discount rate remain constant."
      ],
      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.rebound_adjusted_savings",
      "category": "Circular transition & resilience",
      "title": "Rebound-adjusted resource savings",
      "equation": "Adjusted savings = gross savings × (1 − rebound fraction)",
      "inputs": [
        {
          "key": "grossSavingsTonnes",
          "label": "Gross resource savings",
          "unit": "tonnes/yr",
          "default": 320000
        },
        {
          "key": "reboundFraction",
          "label": "Rebound fraction",
          "unit": "1",
          "default": 0.18
        }
      ],
      "outputs": {
        "adjustedSavingsTonnes": {
          "expression": "grossSavingsTonnes*(1-reboundFraction)",
          "unit": "tonnes/yr"
        }
      },
      "assumptions": [
        "Rebound fraction captures the selected behavioral and market response."
      ],
      "notes": [],
      "version": "0.16.0"
    }
  ]
}

      "notes": [],
      "version": "0.16.0"
    },
    {
      "id": "ce.recycling_rate",
      "category": "Waste prevention & resource recovery",
      "title": "Recycling rate",
      "equation": "Recycling = recycled material / generated waste",
      "inputs": [
        {
          "key": "recycledTonnes",

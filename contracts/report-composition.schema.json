{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/report-composition.schema.json",
  "title": "Sustainable Catalyst Lab report composition",
  "type": "object",
  "required": ["format", "applicationVersion", "id", "templateId", "title", "sections", "createdAt", "updatedAt"],
  "properties": {
    "format": { "const": "sc-lab-report-composition/1.0" },
    "applicationVersion": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "templateId": { "enum": ["technical-report", "experiment-report", "analysis-brief", "decision-brief"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 180 },
    "subtitle": { "type": "string", "maxLength": 240 },
    "executiveSummary": { "type": "string", "maxLength": 8000 },
    "revision": { "type": "integer", "minimum": 0 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "enabled"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "enum": ["cover", "executive-summary", "methods", "assumptions", "results", "figures", "tables", "validation", "limitations", "sources", "appendices", "audit"]
          },
          "title": { "type": "string", "minLength": 1, "maxLength": 180 },
          "enabled": { "type": "boolean" },
          "content": { "type": "string", "maxLength": 50000 },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "compositionFingerprint": { "type": "string" }
  },
  "additionalProperties": true
}

{
  "schema": "sc-lab-mechanical-thermal-catalog/1.0",
  "version": "0.11.0",
  "methodCount": 48,
  "methods": [
    {
      "id": "mt.vector_resultant",
      "category": "Statics",
      "title": "Vector resultant",
      "equation": "R = sqrt(Fx^2 + Fy^2 + Fz^2)",
      "inputs": [
        {
          "key": "fx",
          "label": "Force x",
          "unit": "N",
          "default": 300
        },
        {
          "key": "fy",
          "label": "Force y",
          "unit": "N",
          "default": 400
        },
        {
          "key": "fz",
          "label": "Force z",
          "unit": "N",
          "default": 0
        }
      ],
      "outputs": {
        "resultantN": {
          "expression": "hypot(fx,fy,fz)",
          "unit": "N"
        }
      },
      "assumptions": [
        "Cartesian components share one coordinate frame."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.moment",
      "category": "Statics",
      "title": "Force moment",
      "equation": "M = F d",
      "inputs": [
        {
          "key": "forceN",
          "label": "Force",
          "unit": "N",
          "default": 1200
        },
        {
          "key": "armM",
          "label": "Perpendicular arm",
          "unit": "m",
          "default": 0.35
        }
      ],
      "outputs": {
        "momentNm": {
          "expression": "forceN*armM",
          "unit": "N*m"
        }
      },
      "assumptions": [
        "The arm is perpendicular to the force line of action."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.simple_beam_reactions",
      "category": "Statics",
      "title": "Simply supported beam reactions",
      "equation": "RA=P(L-a)/L; RB=Pa/L",
      "inputs": [
        {
          "key": "loadN",
          "label": "Point load",
          "unit": "N",
          "default": 10000
        },
        {
          "key": "spanM",
          "label": "Span",
          "unit": "m",
          "default": 5
        },
        {
          "key": "distanceM",
          "label": "Load distance from A",
          "unit": "m",
          "default": 2
        }
      ],
      "outputs": {
        "reactionAN": {
          "expression": "loadN*(spanM-distanceM)/spanM",
          "unit": "N"
        },
        "reactionBN": {
          "expression": "loadN*distanceM/spanM",
          "unit": "N"
        }
      },
      "assumptions": [
        "One point load; pin at A and roller at B."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.axial_stress",
      "category": "Strength",
      "title": "Axial normal stress",
      "equation": "sigma = F/A",
      "inputs": [
        {
          "key": "forceN",
          "label": "Axial force",
          "unit": "N",
          "default": 50000
        },
        {
          "key": "areaM2",
          "label": "Area",
          "unit": "m^2",
          "default": 0.001
        }
      ],
      "outputs": {
        "stressPa": {
          "expression": "forceN/areaM2",
          "unit": "Pa"
        }
      },
      "assumptions": [
        "Uniform uniaxial stress."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.axial_strain",
      "category": "Strength",
      "title": "Axial strain",
      "equation": "epsilon = dL/L",
      "inputs": [
        {
          "key": "extensionM",
          "label": "Length change",
          "unit": "m",
          "default": 0.001
        },
        {
          "key": "lengthM",
          "label": "Original length",
          "unit": "m",
          "default": 2
        }
      ],
      "outputs": {
        "strain": {
          "expression": "extensionM/lengthM",
          "unit": "1"
        }
      },
      "assumptions": [
        "Small strain."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.hooke_stress",
      "category": "Strength",
      "title": "Linear elastic stress",
      "equation": "sigma = E epsilon",
      "inputs": [
        {
          "key": "modulusPa",
          "label": "Young modulus",
          "unit": "Pa",
          "default": 200000000000.0
        },
        {
          "key": "strain",
          "label": "Strain",
          "unit": "1",
          "default": 0.001
        }
      ],
      "outputs": {
        "stressPa": {
          "expression": "modulusPa*strain",
          "unit": "Pa"
        }
      },
      "assumptions": [
        "Linear elastic range."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.thermal_expansion",
      "category": "Strength",
      "title": "Linear thermal expansion",
      "equation": "dL = alpha L dT",
      "inputs": [
        {
          "key": "alphaPerK",
          "label": "Expansion coefficient",
          "unit": "1/K",
          "default": 1.2e-05
        },
        {
          "key": "lengthM",
          "label": "Length",
          "unit": "m",
          "default": 3
        },
        {
          "key": "deltaTK",
          "label": "Temperature change",
          "unit": "K",
          "default": 60
        }
      ],
      "outputs": {
        "extensionM": {
          "expression": "alphaPerK*lengthM*deltaTK",
          "unit": "m"
        },
        "finalLengthM": {
          "expression": "lengthM+alphaPerK*lengthM*deltaTK",
          "unit": "m"
        }
      },
      "assumptions": [
        "Constant coefficient."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.torsion_solid_shaft",
      "category": "Strength",
      "title": "Solid circular shaft torsion",
      "equation": "tau=16T/(pi d^3); theta=32TL/(pi Gd^4)",
      "inputs": [
        {
          "key": "torqueNm",
          "label": "Torque",
          "unit": "N*m",
          "default": 2500
        },
        {
          "key": "diameterM",
          "label": "Diameter",
          "unit": "m",
          "default": 0.06
        },
        {
          "key": "lengthM",
          "label": "Length",
          "unit": "m",
          "default": 1.2
        },
        {
          "key": "shearModulusPa",
          "label": "Shear modulus",
          "unit": "Pa",
          "default": 80000000000.0
        }
      ],
      "outputs": {
        "maxShearPa": {
          "expression": "16*torqueNm/(pi*diameterM**3)",
          "unit": "Pa"
        },
        "twistRad": {
          "expression": "32*torqueNm*lengthM/(pi*shearModulusPa*diameterM**4)",
          "unit": "rad"
        }
      },
      "assumptions": [
        "Solid shaft; elastic Saint-Venant torsion."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.bending_stress",
      "category": "Strength",
      "title": "Elastic bending stress",
      "equation": "sigma = Mc/I",
      "inputs": [
        {
          "key": "momentNm",
          "label": "Bending moment",
          "unit": "N*m",
          "default": 12000
        },
        {
          "key": "distanceM",
          "label": "Neutral-axis distance",
          "unit": "m",
          "default": 0.08
        },
        {
          "key": "inertiaM4",
          "label": "Second moment",
          "unit": "m^4",
          "default": 8e-06
        }
      ],
      "outputs": {
        "stressPa": {
          "expression": "momentNm*distanceM/inertiaM4",
          "unit": "Pa"
        }
      },
      "assumptions": [
        "Euler-Bernoulli bending."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.simply_supported_center_deflection",
      "category": "Strength",
      "title": "Simply supported center-load deflection",
      "equation": "delta=PL^3/(48EI)",
      "inputs": [
        {
          "key": "loadN",
          "label": "Center load",
          "unit": "N",
          "default": 5000
        },
        {
          "key": "spanM",
          "label": "Span",
          "unit": "m",
          "default": 4
        },
        {
          "key": "modulusPa",
          "label": "Young modulus",
          "unit": "Pa",
          "default": 200000000000.0
        },
        {
          "key": "inertiaM4",
          "label": "Second moment",
          "unit": "m^4",
          "default": 9e-06
        }
      ],
      "outputs": {
        "deflectionM": {
          "expression": "loadN*spanM**3/(48*modulusPa*inertiaM4)",
          "unit": "m"
        }
      },
      "assumptions": [
        "Prismatic beam; small deflection."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.cantilever_end_deflection",
      "category": "Strength",
      "title": "Cantilever end-load deflection",
      "equation": "delta=PL^3/(3EI)",
      "inputs": [
        {
          "key": "loadN",
          "label": "End load",
          "unit": "N",
          "default": 1000
        },
        {
          "key": "lengthM",
          "label": "Length",
          "unit": "m",
          "default": 2
        },
        {
          "key": "modulusPa",
          "label": "Young modulus",
          "unit": "Pa",
          "default": 200000000000.0
        },
        {
          "key": "inertiaM4",
          "label": "Second moment",
          "unit": "m^4",
          "default": 5e-06
        }
      ],
      "outputs": {
        "deflectionM": {
          "expression": "loadN*lengthM**3/(3*modulusPa*inertiaM4)",
          "unit": "m"
        }
      },
      "assumptions": [
        "Prismatic cantilever; small deflection."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.euler_buckling",
      "category": "Strength",
      "title": "Euler column buckling",
      "equation": "Pcr=pi^2 EI/(KL)^2",
      "inputs": [
        {
          "key": "modulusPa",
          "label": "Young modulus",
          "unit": "Pa",
          "default": 200000000000.0
        },
        {
          "key": "inertiaM4",
          "label": "Second moment",
          "unit": "m^4",
          "default": 4e-06
        },
        {
          "key": "lengthM",
          "label": "Length",
          "unit": "m",
          "default": 3
        },
        {
          "key": "kFactor",
          "label": "Effective-length factor",
          "unit": "1",
          "default": 1
        }
      ],
      "outputs": {
        "criticalLoadN": {
          "expression": "pi**2*modulusPa*inertiaM4/(kFactor*lengthM)**2",
          "unit": "N"
        }
      },
      "assumptions": [
        "Ideal slender elastic column."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.factor_of_safety",
      "category": "Failure",
      "title": "Static factor of safety",
      "equation": "n = allowable/applied",
      "inputs": [
        {
          "key": "allowablePa",
          "label": "Allowable strength",
          "unit": "Pa",
          "default": 250000000.0
        },
        {
          "key": "appliedPa",
          "label": "Applied stress",
          "unit": "Pa",
          "default": 100000000.0
        }
      ],
      "outputs": {
        "factorOfSafety": {
          "expression": "allowablePa/appliedPa",
          "unit": "1"
        }
      },
      "assumptions": [
        "Same failure measure for allowable and applied values."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.von_mises_plane_stress",
      "category": "Failure",
      "title": "Plane-stress von Mises",
      "equation": "sv=sqrt(sx^2-sx sy+sy^2+3t^2)",
      "inputs": [
        {
          "key": "sigmaXPa",
          "label": "Normal stress x",
          "unit": "Pa",
          "default": 120000000.0
        },
        {
          "key": "sigmaYPa",
          "label": "Normal stress y",
          "unit": "Pa",
          "default": 40000000.0
        },
        {
          "key": "tauPa",
          "label": "Shear stress",
          "unit": "Pa",
          "default": 25000000.0
        }
      ],
      "outputs": {
        "vonMisesPa": {
          "expression": "sqrt(sigmaXPa**2-sigmaXPa*sigmaYPa+sigmaYPa**2+3*tauPa**2)",
          "unit": "Pa"
        }
      },
      "assumptions": [
        "Plane-stress ductile yield screening."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.goodman_factor",
      "category": "Failure",
      "title": "Modified Goodman factor",
      "equation": "n=1/(sa/Se+sm/Sut)",
      "inputs": [
        {
          "key": "alternatingPa",
          "label": "Alternating stress",
          "unit": "Pa",
          "default": 80000000.0
        },
        {
          "key": "meanPa",
          "label": "Mean stress",
          "unit": "Pa",
          "default": 60000000.0
        },
        {
          "key": "endurancePa",
          "label": "Endurance limit",
          "unit": "Pa",
          "default": 200000000.0
        },
        {
          "key": "ultimatePa",
          "label": "Ultimate strength",
          "unit": "Pa",
          "default": 500000000.0
        }
      ],
      "outputs": {
        "factorOfSafety": {
          "expression": "1/(alternatingPa/endurancePa+meanPa/ultimatePa)",
          "unit": "1"
        }
      },
      "assumptions": [
        "Corrected endurance limit; tensile mean stress."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.critical_crack_length",
      "category": "Failure",
      "title": "Critical crack length",
      "equation": "a=(KIC/(Y sigma))^2/pi",
      "inputs": [
        {
          "key": "toughnessPaSqrtM",
          "label": "Fracture toughness",
          "unit": "Pa*sqrt(m)",
          "default": 50000000.0
        },
        {
          "key": "geometryFactor",
          "label": "Geometry factor",
          "unit": "1",
          "default": 1.12
        },
        {
          "key": "stressPa",
          "label": "Applied stress",
          "unit": "Pa",
          "default": 150000000.0
        }
      ],
      "outputs": {
        "criticalCrackM": {
          "expression": "(toughnessPaSqrtM/(geometryFactor*stressPa))**2/pi",
          "unit": "m"
        }
      },
      "assumptions": [
        "Mode-I LEFM."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.bolted_joint_preload",
      "category": "Design",
      "title": "Bolt preload from torque",
      "equation": "Fi=T/(Kd)",
      "inputs": [
        {
          "key": "torqueNm",
          "label": "Installation torque",
          "unit": "N*m",
          "default": 120
        },
        {
          "key": "nutFactor",
          "label": "Nut factor",
          "unit": "1",
          "default": 0.2
        },
        {
          "key": "diameterM",
          "label": "Nominal diameter",
          "unit": "m",
          "default": 0.016
        }
      ],
      "outputs": {
        "preloadN": {
          "expression": "torqueNm/(nutFactor*diameterM)",
          "unit": "N"
        }
      },
      "assumptions": [
        "Nut factor represents thread and bearing friction."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.helical_spring_rate",
      "category": "Design",
      "title": "Helical compression spring rate",
      "equation": "k=Gd^4/(8D^3N)",
      "inputs": [
        {
          "key": "shearModulusPa",
          "label": "Shear modulus",
          "unit": "Pa",
          "default": 79000000000.0
        },
        {
          "key": "wireDiameterM",
          "label": "Wire diameter",
          "unit": "m",
          "default": 0.008
        },
        {
          "key": "meanDiameterM",
          "label": "Mean coil diameter",
          "unit": "m",
          "default": 0.05
        },
        {
          "key": "activeCoils",
          "label": "Active coils",
          "unit": "1",
          "default": 8
        }
      ],
      "outputs": {
        "springRateNPerM": {
          "expression": "shearModulusPa*wireDiameterM**4/(8*meanDiameterM**3*activeCoils)",
          "unit": "N/m"
        }
      },
      "assumptions": [
        "Close-coiled round-wire spring."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.gear_ratio_torque",
      "category": "Design",
      "title": "Ideal gear train",
      "equation": "i=Nout/Nin; Tout=Tin i eta",
      "inputs": [
        {
          "key": "inputTeeth",
          "label": "Input teeth",
          "unit": "1",
          "default": 20
        },
        {
          "key": "outputTeeth",
          "label": "Output teeth",
          "unit": "1",
          "default": 60
        },
        {
          "key": "inputTorqueNm",
          "label": "Input torque",
          "unit": "N*m",
          "default": 50
        },
        {
          "key": "efficiency",
          "label": "Efficiency",
          "unit": "1",
          "default": 0.95
        }
      ],
      "outputs": {
        "ratio": {
          "expression": "outputTeeth/inputTeeth",
          "unit": "1"
        },
        "outputTorqueNm": {
          "expression": "inputTorqueNm*(outputTeeth/inputTeeth)*efficiency",
          "unit": "N*m"
        }
      },
      "assumptions": [
        "Single gear pair."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.bearing_l10_life",
      "category": "Design",
      "title": "Rolling-bearing L10 life",
      "equation": "L10=(C/P)^p 10^6 rev",
      "inputs": [
        {
          "key": "dynamicRatingN",
          "label": "Dynamic rating C",
          "unit": "N",
          "default": 50000
        },
        {
          "key": "equivalentLoadN",
          "label": "Equivalent load P",
          "unit": "N",
          "default": 10000
        },
        {
          "key": "lifeExponent",
          "label": "Exponent p",
          "unit": "1",
          "default": 3
        },
        {
          "key": "speedRpm",
          "label": "Speed",
          "unit": "rpm",
          "default": 1200
        }
      ],
      "outputs": {
        "lifeRevolutions": {
          "expression": "(dynamicRatingN/equivalentLoadN)**lifeExponent*1e6",
          "unit": "rev"
        },
        "lifeHours": {
          "expression": "(dynamicRatingN/equivalentLoadN)**lifeExponent*1e6/(60*speedRpm)",
          "unit": "h"
        }
      },
      "assumptions": [
        "Constant load and speed."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.constant_acceleration",
      "category": "Dynamics",
      "title": "Constant-acceleration motion",
      "equation": "v=u+at; s=ut+0.5at^2",
      "inputs": [
        {
          "key": "initialVelocityMps",
          "label": "Initial velocity",
          "unit": "m/s",

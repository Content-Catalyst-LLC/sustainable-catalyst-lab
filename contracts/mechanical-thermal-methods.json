        "Single degree of freedom."
      ],
      "version": "0.11.0"
    },
    {
      "id": "mt.damping_ratio",
      "category": "Vibration",
      "title": "Viscous damping ratio",
      "equation": "zeta=c/(2sqrt(km))",
      "inputs": [
        {
          "key": "dampingNsM",
          "label": "Damping coefficient",
          "unit": "N*s/m",

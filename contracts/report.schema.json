{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/sc-lab-report-1.0.schema.json",
  "title": "Sustainable Catalyst Lab Report",
  "type": "object",
  "required": ["schema", "schemaVersion", "reportType", "title", "analyses", "audit"],
  "properties": {
    "schema": { "const": "sc-lab-report/1.0" },
    "schemaVersion": { "const": "1.0" },
    "reportType": { "enum": ["technical-report", "decision-brief", "evidence-packet", "executive-summary"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "subtitle": { "type": "string", "maxLength": 600 },
    "executiveSummary": { "type": "string", "maxLength": 8000 },
    "pageSize": { "enum": ["LETTER", "A4"] },
    "project": { "type": ["object", "null"] },
    "analyses": { "type": "array", "minItems": 1, "maxItems": 12 },
    "includeAudit": { "type": "boolean" },
    "createdAt": { "type": ["string", "null"] },
    "audit": { "type": "object" }
  },
  "additionalProperties": true
}

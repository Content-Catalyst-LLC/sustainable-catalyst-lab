{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/urban-planning-spatial-analysis-v1.schema.json",
  "title": "Sustainable Catalyst Lab Urban Planning and Spatial Systems Analysis",
  "type": "object",
  "required": [
    "schema",
    "version",
    "methodId",
    "category",
    "title",
    "inputs",
    "outputs",
    "validation",
    "audit"
  ],
  "properties": {
    "schema": {
      "const": "sc-lab-urban-planning-spatial-analysis/1.0"
    },
    "version": {
      "const": "0.14.0"
    },
    "methodId": {
      "type": "string",
      "pattern": "^up\\."
    },
    "category": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object"
    },
    "audit": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
